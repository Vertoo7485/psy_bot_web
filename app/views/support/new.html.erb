<div class="container py-5">
  <div class="row">
    <div class="col-lg-6 offset-lg-3">
      <div class="card">
        <div class="card-header bg-primary text-white">
          <h3 class="mb-0">
            <i class="fas fa-headset me-2"></i>
            Связаться с поддержкой
          </h3>
        </div>
        <div class="card-body">
          <%= form_tag support_path, method: :post do %>
            <div class="mb-3">
              <%= label_tag :name, "Ваше имя", class: "form-label" %>
              <%= text_field_tag :name, @name, class: "form-control", required: true %>
            </div>

            <div class="mb-3">
              <%= label_tag :message, "Сообщение", class: "form-label" %>
              <%= text_area_tag :message, nil, rows: 5, class: "form-control", required: true %>
            </div>

            <div class="text-center">
              <%= submit_tag "Отправить", class: "btn btn-success btn-lg px-5" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>