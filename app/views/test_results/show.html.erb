<% 
  score = JSON.parse(@result.score) rescue { "situational" => 0, "personal" => 0, "total" => 0 }
  interpretation = JSON.parse(@result.interpretation) rescue { "situational" => "", "personal" => "" }
  
  situational = score["situational"]
  personal = score["personal"]
  total = situational + personal
%>

<div class="container py-5">
  <div class="row">
    <div class="col-lg-8 mx-auto">
      <!-- Кнопка назад -->
      <%= link_to tests_path, class: "btn btn-link text-secondary mb-4 p-0" do %>
        <i class="fas fa-arrow-left me-2"></i>К списку тестов
      <% end %>
      
      <!-- Результаты -->
      <div class="card">
        <div class="card-header bg-success text-white">
          <h3 class="mb-0">
            <i class="fas fa-chart-pie me-2"></i>
            Ваши результаты
          </h3>
        </div>
        
        <div class="card-body">
          <h4 class="text-center mb-4"><%= @test.title %></h4>
          
          <!-- График результатов -->
          <div class="row g-4 mb-5">
            <div class="col-md-6">
              <div class="card bg-light border-0">
                <div class="card-body text-center">
                  <h5 class="mb-3">Ситуативная тревожность</h5>
                  <div class="display-4 mb-2" style="color: <%= situational > 45 ? '#dc3545' : (situational > 30 ? '#ffc107' : '#28a745') %>">
                    <%= situational %>
                  </div>
                  <div class="progress mb-3" style="height: 10px;">
                    <div class="progress-bar <%= situational > 45 ? 'bg-danger' : (situational > 30 ? 'bg-warning' : 'bg-success') %>" 
                         style="width: <%= (situational.to_f / 80 * 100) %>%"></div>
                  </div>
                  <p class="mb-0"><%= interpretation["situational"] %></p>
                </div>
              </div>
            </div>
            
            <div class="col-md-6">
              <div class="card bg-light border-0">
                <div class="card-body text-center">
                  <h5 class="mb-3">Личностная тревожность</h5>
                  <div class="display-4 mb-2" style="color: <%= personal > 45 ? '#dc3545' : (personal > 30 ? '#ffc107' : '#28a745') %>">
                    <%= personal %>
                  </div>
                  <div class="progress mb-3" style="height: 10px;">
                    <div class="progress-bar <%= personal > 45 ? 'bg-danger' : (personal > 30 ? 'bg-warning' : 'bg-success') %>" 
                         style="width: <%= (personal.to_f / 80 * 100) %>%"></div>
                  </div>
                  <p class="mb-0"><%= interpretation["personal"] %></p>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Рекомендации -->
          <div class="alert alert-info">
            <h5 class="alert-heading mb-3">
              <i class="fas fa-lightbulb me-2"></i>
              Рекомендации
            </h5>
            
            <% if situational > 45 %>
              <p class="mb-2"><%= @test.config["recommendations"]["situational_high"] %></p>
            <% else %>
              <p class="mb-2"><%= @test.config["recommendations"]["situational_low"] %></p>
            <% end %>
            
            <% if personal > 45 %>
              <p class="mb-0"><%= @test.config["recommendations"]["personal_high"] %></p>
            <% else %>
              <p class="mb-0"><%= @test.config["recommendations"]["personal_low"] %></p>
            <% end %>
          </div>
          
          <!-- Кнопки действий -->
          <div class="d-flex justify-content-between mt-5">
            <%= link_to test_path(@test), class: "btn btn-outline-primary" do %>
              <i class="fas fa-redo me-2"></i>Пройти заново
            <% end %>
            
            <%= link_to profile_path, class: "btn btn-outline-secondary" do %>
              <i class="fas fa-user-circle me-2"></i>В профиль
            <% end %>
            
            <button class="btn btn-success" onclick="window.print()">
              <i class="fas fa-download me-2"></i>Сохранить
            </button>
          </div>
          
          <p class="text-muted text-center mt-4 small">
            <i class="far fa-calendar-alt me-1"></i>
            Пройден: <%= @result.completed_at.strftime('%d.%m.%Y в %H:%M') %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>