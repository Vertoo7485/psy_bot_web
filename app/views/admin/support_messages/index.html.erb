<div class="container py-4">
  <h1 class="mb-4">Сообщения поддержки</h1>
  
  <table class="table">
    <thead>
      <tr>
        <th>Статус</th>
        <th>Имя</th>
        <th>Сообщение</th>
        <th>Дата</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      <% @messages.each do |msg| %>
        <tr>
          <td>
            <% if msg.read_at.nil? %>
              <span class="badge bg-danger">Новое</span>
            <% else %>
              <span class="badge bg-secondary">Прочитано</span>
            <% end %>
          </td>
          <td><%= msg.name %></td>
          <td><%= truncate(msg.message, length: 50) %></td>
          <td><%= msg.created_at.strftime('%d.%m.%Y %H:%M') %></td>
          <td>
            <%= link_to "Просмотр", admin_support_message_path(msg), class: "btn btn-sm btn-outline-primary" %>
            <%= link_to "Удалить", admin_support_message_path(msg), method: :delete, class: "btn btn-sm btn-outline-danger", data: { confirm: "Удалить?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>