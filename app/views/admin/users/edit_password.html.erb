<div class="container py-4">
  <h1 class="mb-4">Смена пароля для пользователя: <%= @user.email %></h1>
  
  <%= form_with model: @user, url: update_password_admin_user_path(@user), method: :patch, local: true do |f| %>
    <div class="card">
      <div class="card-body">
        <div class="mb-3">
          <%= f.label :password, "Новый пароль", class: "form-label" %>
          <%= f.password_field :password, class: "form-control", required: true %>
          <small class="text-muted">Минимум 6 символов</small>
        </div>

        <div class="mb-3">
          <%= f.label :password_confirmation, "Подтверждение пароля", class: "form-label" %>
          <%= f.password_field :password_confirmation, class: "form-control", required: true %>
        </div>

        <div class="d-flex justify-content-between">
          <%= link_to "Назад", admin_user_path(@user), class: "btn btn-secondary" %>
          <%= f.submit "Сменить пароль", class: "btn btn-warning" %>
        </div>
      </div>
    </div>
  <% end %>
</div>