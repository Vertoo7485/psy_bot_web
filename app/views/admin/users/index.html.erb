<div class="container py-4">
  <h1 class="mb-4">Все пользователи</h1>
  
  <table class="table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Email</th>
        <th>Статус</th>
        <th>Триал до</th>
        <th>Подписка до</th>
        <th>Дней пройдено</th>
        <th>Дата регистрации</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.id %></td>
          <td><%= user.email %></td>
          <td>
            <% if user.admin? %>
              <span class="badge bg-danger">Админ</span>
            <% elsif user.premium? %>
              <span class="badge bg-success">Премиум</span>
            <% else %>
              <span class="badge bg-secondary">Бесплатный</span>
            <% end %>
          </td>
          <td><%= user.trial_ends_at&.strftime('%d.%m.%Y') || '-' %></td>
          <td><%= user.subscription_ends_at&.strftime('%d.%m.%Y') || '-' %></td>
          <td><%= user.user_day_progresses.where(completed: true).count %>/<%= Day.count %></td>
          <td><%= user.created_at.strftime('%d.%m.%Y') %></td>
          <td><%= link_to "Просмотр", admin_user_path(user), class: "btn btn-sm btn-outline-primary" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  
  <%= paginate @users %>
</div>