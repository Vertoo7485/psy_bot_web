<script>
  document.addEventListener('DOMContentLoaded', function() {
    console.log('Day 11 script loaded')
    
    const startBtn = document.getElementById('startGroundingExercise')
    const container = document.getElementById('groundingStepsContainer')
    
    // Шаги заземления из seeds
    const steps = <%= raw content["grounding_steps"].to_json %>
    
    let currentStep = 0
    let answers = []
    
    if (startBtn) {
      startBtn.addEventListener('click', function() {
        console.log('Start grounding clicked')
        startBtn.style.display = 'none'
        container.style.display = 'block'
        currentStep = 0
        showStep()
      })
    }
    
    function showStep() {
      if (currentStep >= steps.length) {
        showCompletion()
        return
      }
      
      const step = steps[currentStep]
      
      // Подсказки для каждого шага
      const examples = step.examples || []
      
      let examplesHtml = ''
      if (examples.length > 0) {
        examplesHtml = `
          <div class="mb-2">
            <small class="text-secondary">Подсказки:</small>
            <ul class="small">
              ${examples.map(ex => `<li>${ex}</li>`).join('')}
            </ul>
          </div>
        `
      }
      
      let stepHtml = `
        <div class="card mb-4" id="step${currentStep}">
          <div class="card-header bg-primary text-white">
            <h6 class="mb-0">${step.emoji} Шаг ${step.step}: ${step.title}</h6>
          </div>
          <div class="card-body">
            <p class="mb-3">${step.description}</p>
            
            ${examplesHtml}
            
            <div class="alert alert-light small mb-3">
              <i class="fas fa-info-circle me-1"></i> ${step.fact}
            </div>
            
            <p class="text-secondary small mb-1"><i>Например:</i> ${step.placeholder}</p>
            <textarea class="form-control" id="step${currentStep}Input" rows="3" placeholder="Напишите ${step.min_count} ${step.sense} через запятую..."></textarea>
            
            <div class="text-end mt-3">
              <button class="btn btn-success" onclick="saveStep(${currentStep})">
                ${currentStep < steps.length - 1 ? 'Далее' : 'Завершить'}
              </button>
            </div>
          </div>
        </div>
      `
      
      container.innerHTML = stepHtml
      container.scrollIntoView({ behavior: 'smooth' })
    }
    
    window.saveStep = function(stepNumber) {
      const input = document.getElementById(`step${stepNumber}Input`)
      const value = input.value.trim()
      
      if (!value) {
        alert('Пожалуйста, напишите ответ')
        return
      }
      
      // Проверяем количество элементов
      const items = value.split(/[,;.\s\n]+/).filter(i => i.trim() !== '')
      
      if (items.length < steps[stepNumber].min_count) {
        alert(`Пожалуйста, назовите минимум ${steps[stepNumber].min_count} ${steps[stepNumber].sense}`)
        return
      }
      
      answers[stepNumber] = {
        items: items,
        text: value,
        step: steps[stepNumber]
      }
      
      currentStep++
      
      document.getElementById(`step${stepNumber}`).remove()
      
      if (currentStep < steps.length) {
        showStep()
      } else {
        showCompletion()
      }
    }
    
    function showCompletion() {
      let summary = '<div class="alert alert-success mb-3"><strong>Ваши ответы:</strong></div>'
      
      steps.forEach((step, index) => {
        if (answers[index]) {
          summary += `
            <div class="card mb-2">
              <div class="card-body py-2">
                <small class="text-primary fw-bold">${step.emoji} Шаг ${step.step}</small>
                <p class="small mb-0">${answers[index].text}</p>
              </div>
            </div>
          `
        }
      })
      
      container.innerHTML = `
        <div class="card mb-4 border-success">
          <div class="card-header bg-success text-white">
            <h6 class="mb-0">✅ Практика заземления завершена!</h6>
          </div>
          <div class="card-body">
            <p class="mb-3">Вы только что прошли все 5 шагов техники 5-4-3-2-1!</p>
            
            ${summary}
            
            <p class="text-secondary small mt-3">
              <i class="fas fa-info-circle me-1"></i>
              Ваши ответы сохранены. Теперь у вас есть личный инструмент экстренной самопомощи.
            </p>
            
            <div class="text-center mt-4">
              <button class="btn btn-success" id="completeDay11">
                <i class="fas fa-check-circle me-2"></i>Завершить день
              </button>
            </div>
          </div>
        </div>
      `
      
      saveToDatabase()
    }
    
    function saveToDatabase() {
      console.log('Saving to database:', answers)
      
      fetch('/grounding_exercise_entries', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
        },
        body: JSON.stringify({
          entry: {
            seen: answers[0]?.items || [],
            touched: answers[1]?.items || [],
            heard: answers[2]?.items || [],
            smelled: answers[3]?.items || [],
            tasted: answers[4]?.items || []
          }
        })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          console.log('Saved successfully')
        } else {
          console.error('Save error:', data.error)
        }
      })
      .catch(error => {
        console.error('Error:', error)
      })
    }
    
    // Завершение дня
    document.addEventListener('click', function(e) {
      if (e.target && e.target.id === 'completeDay11') {
        console.log('Complete day 11 clicked')
        
        const reflectionSection = document.getElementById('reflectionSection')
        if (reflectionSection) {
          reflectionSection.classList.remove('d-none')
          reflectionSection.scrollIntoView({ behavior: 'smooth' })
        }
        
        const completeDayBtn = document.getElementById('completeDay')
        if (completeDayBtn) {
          completeDayBtn.classList.remove('d-none')
        }
      }
    })
  })
</script>