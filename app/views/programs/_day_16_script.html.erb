<script>
  document.addEventListener('DOMContentLoaded', function() {
    console.log('Day 16 script loaded')
    
    const startBtn = document.getElementById('startReconnectionExercise')
    const container = document.getElementById('reconnectionStepsContainer')
    
    // Шаги из seeds
    const steps = <%= raw content["steps"].to_json %>
    
    let currentStep = 0
    let answers = []
    
    if (startBtn) {
      startBtn.addEventListener('click', function() {
        console.log('Start reconnection clicked')
        startBtn.style.display = 'none'
        container.style.display = 'block'
        currentStep = 0
        showStep()
      })
    }
    
    function showStep() {
      if (currentStep >= steps.length) {
        showCompletion()
        return
      }
      
      const step = steps[currentStep]
      
      // Примеры для каждого шага
      const examples = step.examples || []
      
      let examplesHtml = ''
      if (examples.length > 0) {
        examplesHtml = `
          <div class="mb-2">
            <small class="text-secondary">Подсказки:</small>
            <ul class="small">
              ${examples.map(ex => `<li>${ex}</li>`).join('')}
            </ul>
          </div>
        `
      }
      
      // Для шага 4 (исполнение) показываем кнопку подтверждения
      if (step.step === 4) {
        let stepHtml = `
          <div class="card mb-4" id="step${currentStep}">
            <div class="card-header bg-primary text-white">
              <h6 class="mb-0">${step.emoji} Шаг ${step.step}: ${step.title}</h6>
            </div>
            <div class="card-body">
              <p class="mb-3">${step.description}</p>
              
              <div class="alert alert-light small mb-3">
                <i class="fas fa-info-circle me-1"></i> ${step.fact}
              </div>
              
              <p class="fw-bold mb-2">Ваш план:</p>
              <p class="bg-light p-2 rounded">${answers[1] || 'не выбран'}</p>
              <p class="bg-light p-2 rounded">${answers[2] || 'начало не подготовлено'}</p>
              
              <div class="text-center mt-4">
                <button class="btn btn-success" onclick="saveStep(${currentStep})">
                  Я связался(ась)
                </button>
              </div>
            </div>
          </div>
        `
        container.innerHTML = stepHtml
        container.scrollIntoView({ behavior: 'smooth' })
        return
      }
      
      // Для остальных шагов
      let stepHtml = `
        <div class="card mb-4" id="step${currentStep}">
          <div class="card-header bg-primary text-white">
            <h6 class="mb-0">${step.emoji} Шаг ${step.step}: ${step.title}</h6>
          </div>
          <div class="card-body">
            <p class="mb-3">${step.description}</p>
            
            ${examplesHtml}
            
            <div class="alert alert-light small mb-3">
              <i class="fas fa-info-circle me-1"></i> ${step.fact}
            </div>
            
            <p class="text-secondary small mb-1"><i>Например:</i> ${step.placeholder}</p>
            <textarea class="form-control" id="step${currentStep}Input" rows="3" placeholder="Напишите ваш ответ..."></textarea>
            
            <div class="text-end mt-3">
              <button class="btn btn-success" onclick="saveStep(${currentStep})">
                ${currentStep < steps.length - 1 ? 'Далее' : 'Завершить'}
              </button>
            </div>
          </div>
        </div>
      `
      
      container.innerHTML = stepHtml
      container.scrollIntoView({ behavior: 'smooth' })
    }
    
    window.saveStep = function(stepNumber) {
      if (stepNumber === 3) { // Шаг 4 (индекс 3) - исполнение
        answers[stepNumber] = 'выполнено'
        currentStep = 4
        document.getElementById('step3')?.remove()
        showStep()
        return
      }
      
      const input = document.getElementById(`step${stepNumber}Input`)
      if (!input) return
      
      const value = input.value.trim()
      
      if (!value) {
        alert('Пожалуйста, напишите ответ')
        return
      }
      
      answers[stepNumber] = value
      currentStep++
      
      document.getElementById(`step${stepNumber}`).remove()
      
      if (currentStep < steps.length) {
        showStep()
      } else {
        showCompletion()
      }
    }
    
    function showCompletion() {
      let summary = '<div class="alert alert-success mb-3"><strong>Ваш опыт восстановления связи:</strong></div>'
      
      if (answers[0]) {
        summary += `
          <div class="card mb-2">
            <div class="card-body py-2">
              <small class="text-primary fw-bold">🗺️ Люди для связи:</small>
              <p class="small mb-0">${answers[0]}</p>
            </div>
          </div>
        `
      }
      
      if (answers[1]) {
        summary += `
          <div class="card mb-2">
            <div class="card-body py-2">
              <small class="text-primary fw-bold">🎯 Выбрано:</small>
              <p class="small mb-0">${answers[1]}</p>
            </div>
          </div>
        `
      }
      
      if (answers[4]) {
        summary += `
          <div class="card mb-2">
            <div class="card-body py-2">
              <small class="text-primary fw-bold">💭 Рефлексия:</small>
              <p class="small mb-0">${answers[4]}</p>
            </div>
          </div>
        `
      }
      
      if (answers[5]) {
        summary += `
          <div class="card mb-2">
            <div class="card-body py-2">
              <small class="text-primary fw-bold">🔄 План поддержания:</small>
              <p class="small mb-0">${answers[5]}</p>
            </div>
          </div>
        `
      }
      
      container.innerHTML = `
        <div class="card mb-4 border-success">
          <div class="card-header bg-success text-white">
            <h6 class="mb-0">✅ Практика восстановления связей завершена!</h6>
          </div>
          <div class="card-body">
            <p class="mb-3">Вы сделали важный шаг к укреплению социальных связей! 🌉</p>
            
            ${summary}
            
            <p class="text-secondary small mt-3">
              <i class="fas fa-info-circle me-1"></i>
              Регулярное поддержание связей повышает качество жизни на 25-35%.
            </p>
            
            <div class="text-center mt-4">
              <button class="btn btn-success" id="completeDay16">
                <i class="fas fa-check-circle me-2"></i>Завершить день
              </button>
            </div>
          </div>
        </div>
      `
      
      saveToDatabase()
    }
    
    function saveToDatabase() {
      console.log('Saving to database:', answers)
      
      // Парсим имя и формат из шага 2
      let person = answers[1] || ''
      let format = 'сообщение'
      
      if (person.includes('-')) {
        const parts = person.split('-')
        person = parts[0].trim()
        format = parts[1].trim().toLowerCase()
      }
      
      fetch('/reconnection_practices', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
        },
        body: JSON.stringify({
          practice: {
            reconnected_person: person,
            communication_format: format,
            conversation_start: answers[2] || '',
            reflection_text: answers[4] || '',
            integration_plan: answers[5] || ''
          }
        })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          console.log('Saved successfully')
        } else {
          console.error('Save error:', data.error)
        }
      })
      .catch(error => {
        console.error('Error:', error)
      })
    }
    
    // Завершение дня
    document.addEventListener('click', function(e) {
      if (e.target && e.target.id === 'completeDay16') {
        console.log('Complete day 16 clicked')
        
        const reflectionSection = document.getElementById('reflectionSection')
        if (reflectionSection) {
          reflectionSection.classList.remove('d-none')
          reflectionSection.scrollIntoView({ behavior: 'smooth' })
        }
        
        const completeDayBtn = document.getElementById('completeDay')
        if (completeDayBtn) {
          completeDayBtn.classList.remove('d-none')
        }
      }
    })
  })
</script>