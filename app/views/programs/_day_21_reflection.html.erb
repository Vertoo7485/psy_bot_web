<!-- Интерактивная часть дня 21 -->
<div class="mt-4">
  <!-- Теплое приветствие -->
  <div class="text-center mb-4">
    <h5 class="mb-3">🏆 День 21: Рефлексия 3 недель</h5>
    <p class="lead"><strong>21 день — важная веха.</strong> Сегодня мы осмыслим весь путь и создадим план на финальную неделю.</p>
  </div>
  
  <!-- Простое объяснение -->
  <div class="alert alert-info mb-4">
    <i class="fas fa-heart me-2"></i>
    <strong>3 недели регулярной практики</strong> — это время, когда мозг начинает формировать устойчивые нейронные связи. То, что раньше требовало усилий, становится естественнее.
  </div>
  
  <!-- Статистика для мотивации -->
  <div class="row mb-4">
    <div class="col-6 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-success mb-0">21</h4>
          <small>день практики</small>
        </div>
      </div>
    </div>
    <div class="col-6 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-primary mb-0">20+</h4>
          <small>техник освоено</small>
        </div>
      </div>
    </div>
    <div class="col-6 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-warning mb-0">75%</h4>
          <small>программы</small>
        </div>
      </div>
    </div>
    <div class="col-6 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-danger mb-0">7</h4>
          <small>дней до финала</small>
        </div>
      </div>
    </div>
  </div>
  
  <!-- 6 категорий рефлексии (свернуто) -->
  <div class="accordion mb-4">
    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#reflectionCategories">
          📝 6 категорий рефлексии (нажмите для справки)
        </button>
      </h2>
      <div id="reflectionCategories" class="accordion-collapse collapse">
        <div class="accordion-body">
          <div class="row">
            <% content["reflection_categories"].each do |cat| %>
              <div class="col-12 mb-3">
                <span class="badge bg-success me-2"><%= cat["emoji"] %></span> 
                <strong><%= cat["name"] %></strong>
                <p class="text-secondary small mt-1 ms-4"><%= cat["prompt"] %></p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Мотивационная цитата -->
  <div class="card mb-4 bg-light">
    <div class="card-body">
      <p class="fst-italic mb-0"><%= content["motivational_quotes"].sample %></p>
    </div>
  </div>
  
  <!-- Кнопка начала -->
  <div class="text-center mt-4">
    <button class="btn btn-success btn-lg px-5" id="startThreeWeeksReflection">
      <i class="fas fa-pen me-2"></i>Начать рефлексию 3 недель
    </button>
    <p class="text-secondary small mt-2">6 категорий, 10-15 минут. Ответьте на вопросы честно и подробно.</p>
  </div>
  
  <!-- Контейнер для шагов -->
  <div id="reflectionContainer" style="display: none;"></div>
</div>