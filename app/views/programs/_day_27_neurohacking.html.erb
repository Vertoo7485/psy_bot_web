<!-- Интерактивная часть дня 27 -->
<div class="mt-4">
  <!-- Теплое приветствие -->
  <div class="text-center mb-4">
    <h5 class="mb-3">🧠 День 27: Нейрохакинг радости</h5>
    <p class="lead"><strong>Учимся научно обоснованным способам</strong> получать удовольствие от достижений и укреплять нейронные пути счастья.</p>
  </div>
  
  <!-- Простое объяснение -->
  <div class="alert alert-info mb-4">
    <i class="fas fa-heart me-2"></i>
    <strong>Ваш мозг — это пластичная система.</strong> Как мышца, которую можно тренировать. Сегодня вы научитесь тренировать его на радость.
  </div>
  
  <!-- Научные факты простыми словами -->
  <div class="row mb-4">
    <div class="col-6 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-success mb-0">25-35%</h4>
          <small>усиление связей</small>
        </div>
      </div>
    </div>
    <div class="col-6 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-primary mb-0">40%</h4>
          <small>эффективнее радость</small>
        </div>
      </div>
    </div>
    <div class="col-6 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-warning mb-0">50-60%</h4>
          <small>восстановление дофамина</small>
        </div>
      </div>
    </div>
    <div class="col-6 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-danger mb-0">65%</h4>
          <small>меньше выгорания</small>
        </div>
      </div>
    </div>
  </div>
  
  <!-- 8 шагов (свернуто) -->
  <div class="accordion mb-4">
    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#neuroSteps">
          🧠 8 шагов к научному празднованию (нажмите для справки)
        </button>
      </h2>
      <div id="neuroSteps" class="accordion-collapse collapse">
        <div class="accordion-body">
          <div class="row">
            <% content["steps"].each do |step| %>
              <div class="col-12 mb-3">
                <span class="badge bg-success me-2"><%= step["step"] %></span> 
                <strong><%= step["emoji"] %> <%= step["title"] %></strong>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Мудрость дня -->
  <div class="card mb-4 bg-light">
    <div class="card-body">
      <p class="fst-italic mb-0">«Радость не в масштабе события, а в масштабе внимания, которое вы ему уделяете.»</p>
      <p class="text-end mb-0">— Рик Хэнсон</p>
    </div>
  </div>
  
  <!-- Кнопка начала -->
  <div class="text-center mt-4">
    <button class="btn btn-success btn-lg px-5" id="startNeurohacking">
      <i class="fas fa-brain me-2"></i>Начать нейрохакинг
    </button>
    <p class="text-secondary small mt-2">8 шагов к научному празднованию, 25-30 минут.</p>
  </div>
  
  <!-- Контейнер для шагов -->
  <div id="neuroContainer" style="display: none;"></div>
</div>