<!-- Интерактивная часть дня 25 -->
<div class="mt-4">
  <!-- Теплое приветствие -->
  <div class="text-center mb-4">
    <h5 class="mb-3">🌌 День 25: Стоический 'Вид сверху'</h5>
    <p class="lead"><strong>Учимся видеть любую ситуацию с космической перспективы</strong> для обретения мудрости и спокойствия.</p>
  </div>
  
  <!-- Простое объяснение -->
  <div class="alert alert-info mb-4">
    <i class="fas fa-heart me-2"></i>
    <strong>Техника стоиков</strong> — способность видеть ситуацию с высоты вселенной, использовать для обретения объективности и снижения тревоги.
  </div>
  
  <!-- Научные факты -->
  <div class="row mb-4">
    <div class="col-6 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-success mb-0">40-60%</h4>
          <small>активация мозга</small>
        </div>
      </div>
    </div>
    <div class="col-6 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-primary mb-0">35-50%</h4>
          <small>меньше тревоги</small>
        </div>
      </div>
    </div>
    <div class="col-6 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-warning mb-0">45%</h4>
          <small>лучше решения</small>
        </div>
      </div>
    </div>
    <div class="col-6 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-danger mb-0">7</h4>
          <small>уровней</small>
        </div>
      </div>
    </div>
  </div>
  
  <!-- 7 уровней (свернуто) -->
  <div class="accordion mb-4">
    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#viewLevels">
          🚀 7 уровней космического восхождения (нажмите для справки)
        </button>
      </h2>
      <div id="viewLevels" class="accordion-collapse collapse">
        <div class="accordion-body">
          <div class="row">
            <% content["perspective_levels"].each do |level| %>
              <div class="col-12 mb-3">
                <span class="badge bg-success me-2"><%= level["level"] %></span> 
                <strong><%= level["emoji"] %> <%= level["title"] %></strong>
                <p class="text-secondary small mt-1 ms-4"><%= level["instruction"] %></p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Философская мудрость -->
  <div class="card mb-4 bg-light">
    <div class="card-body">
      <p class="fst-italic mb-0">«Широкий взгляд усмиряет душу.»</p>
      <p class="text-end mb-0">— Марк Аврелий</p>
    </div>
  </div>
  
  <!-- Кнопка начала -->
  <div class="text-center mt-4">
    <button class="btn btn-success btn-lg px-5" id="startViewFromAbove">
      <i class="fas fa-rocket me-2"></i>Начать космическое путешествие
    </button>
    <p class="text-secondary small mt-2">7 уровней перспективы, 15-20 минут.</p>
  </div>
  
  <!-- Контейнер для шагов -->
  <div id="viewContainer" style="display: none;"></div>
</div>