<script>
  document.getElementById('saveGratitudeSteps')?.addEventListener('click', function() {
    const inputs = document.querySelectorAll('.gratitude-step-input')
    const entries = []
    
    inputs.forEach(input => {
      if (input.value.trim()) {
        entries.push({ text: input.value.trim() })
      }
    })
    
    if (entries.length === 0) {
      alert('Напишите хотя бы одну благодарность')
      return
    }
    
    fetch('/gratitude_entries', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      },
      body: JSON.stringify({ entries: entries })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        alert('✅ Благодарности сохранены!')
        document.getElementById('reflectionSection').classList.remove('d-none')
        document.getElementById('completeDay').classList.remove('d-none')
        document.getElementById('reflectionSection').scrollIntoView({ behavior: 'smooth' })
      } else {
        alert('Ошибка: ' + data.error)
      }
    })
  })
</script>