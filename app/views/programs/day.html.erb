  .rest-card .card-footer {
    pointer-events: auto; /* Футер с кнопкой получает клики */
  }
  </style>
</div>

<!-- JavaScript для сохранения благодарностей -->
<script>
  document.getElementById('saveGratitudeSteps')?.addEventListener('click', function() {
    const inputs = document.querySelectorAll('.gratitude-step-input')
    const entries = []
    
    inputs.forEach(input => {
      if (input.value.trim()) {
        entries.push({ text: input.value.trim() })
      }
    })
    
    if (entries.length === 0) {
      alert('Напишите хотя бы одну благодарность')
      return
    }
    
    fetch('/gratitude_entries', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      },
      body: JSON.stringify({ entries: entries })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        alert('✅ Благодарности сохранены!')
        // Показываем рефлексию и кнопку завершения
        document.getElementById('reflectionSection').classList.remove('d-none')
        document.getElementById('completeDay').classList.remove('d-none')
        // Прокручиваем к рефлексии
        document.getElementById('reflectionSection').scrollIntoView({ behavior: 'smooth' })
      } else {
        alert('Ошибка: ' + data.error)
      }
    })
  })
</script>

<!-- JavaScript для дня 7 -->
<% if day.day_number == 7 %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    let currentCategory = 0
    const totalCategories = <%= content["reflection_categories"].size %>
    const reflections = {}
    
    // Обновление прогресса
    function updateProgress() {
      const progress = ((currentCategory) / totalCategories) * 100
      document.querySelector('#reflectionProgress .progress-bar').style.width = progress + '%'
    }
    
    // Сохранение ответа
    function saveReflection(categoryIndex, text) {
      if (text.trim()) {
        reflections[categoryIndex] = text.trim()
        
        // Показываем следующую категорию
        document.querySelector(`.reflection-category[data-category="${categoryIndex}"]`).style.display = 'none'
        currentCategory++
        
        if (currentCategory < totalCategories) {
          document.querySelector(`.reflection-category[data-category="${currentCategory}"]`).style.display = 'block'
          updateProgress()
        } else {
          // Все категории пройдены
          document.getElementById('reflectionCategories').style.display = 'none'
          document.getElementById('reflectionComplete').style.display = 'block'
          updateProgress()
          
          // Сохраняем все ответы в базу
          saveAllReflections()
        }
      } else {
        alert('Пожалуйста, напишите ваш ответ или нажмите "Пропустить"')
      }
    }
    
    // Сохранение всех ответов
    function saveAllReflections() {
      const entries = []
      const categories = <%= raw content["reflection_categories"].to_json %>
      
      for (let i = 0; i < totalCategories; i++) {
        if (reflections[i]) {
          entries.push({
            text: reflections[i],
            category: categories[i].name
          })
        }
      }
      
      if (entries.length > 0) {
        fetch('/reflection_entries', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
          },
          body: JSON.stringify({ entries: entries })
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            console.log('Рефлексия сохранена')
            // Показываем кнопку завершения дня
            document.getElementById('completeDay').classList.remove('d-none')
          } else {
            alert('Ошибка при сохранении: ' + data.error)
          }
        })
        .catch(error => {
          console.error('Error:', error)
          alert('Ошибка при сохранении. Попробуйте еще раз.')
        })
      } else {
        document.getElementById('completeDay').classList.remove('d-none')
      }
    }
    
    // Обработчики кнопок
    document.querySelectorAll('.save-reflection').forEach(btn => {
      btn.addEventListener('click', function() {
        const category = this.dataset.category
        const input = document.querySelector(`.reflection-input[data-category="${category}"]`)
        saveReflection(parseInt(category), input.value)
      })
    })
    
    document.querySelectorAll('.skip-reflection').forEach(btn => {
      btn.addEventListener('click', function() {
        const category = parseInt(this.dataset.category)
        
        document.querySelector(`.reflection-category[data-category="${category}"]`).style.display = 'none'
        currentCategory++
        
        if (currentCategory < totalCategories) {
          document.querySelector(`.reflection-category[data-category="${currentCategory}"]`).style.display = 'block'
          updateProgress()
        } else {
          document.getElementById('reflectionCategories').style.display = 'none'
          document.getElementById('reflectionComplete').style.display = 'block'
          updateProgress()
          saveAllReflections()
        }
      })
    })
  })
</script>
<% end %>

<!-- JavaScript для дня 8 (упрощенный) -->
<% if day.day_number == 8 %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    let selectedSignal = null
    let selectedStrategy = null
    let selectedSignalName = ''
    let selectedStrategyName = ''
    
    // Выбор стоп-сигнала
    document.querySelectorAll('.select-signal').forEach(btn => {
      btn.addEventListener('click', function() {
        const card = this.closest('.signal-card')
        const signalIndex = this.dataset.signal
        selectedSignal = signalIndex
        selectedSignalName = card.querySelector('.card-title').textContent
        
        // Визуальное выделение
        document.querySelectorAll('.signal-card').forEach(c => {
          c.classList.remove('border-primary', 'border-2', 'bg-light')
        })
        card.classList.add('border-primary', 'border-2', 'bg-light')
        
        // Показываем следующий шаг
        document.getElementById('strategySection').style.display = 'block'
        
        // Прокручиваем к стратегиям
        document.getElementById('strategySection').scrollIntoView({ behavior: 'smooth', block: 'center' })
      })
    })
    
    // Выбор стратегии
    document.querySelectorAll('.select-strategy').forEach(btn => {
      btn.addEventListener('click', function() {
        const card = this.closest('.strategy-card')
        const strategyIndex = this.dataset.strategy
        selectedStrategy = strategyIndex
        selectedStrategyName = card.querySelector('.card-title').textContent
        
        // Визуальное выделение
        document.querySelectorAll('.strategy-card').forEach(c => {
          c.classList.remove('border-primary', 'border-2', 'bg-light')
        })
        card.classList.add('border-primary', 'border-2', 'bg-light')
        
        // Показываем следующий шаг
        document.getElementById('thoughtSection').style.display = 'block'
        
        // Прокручиваем к вводу мысли
        document.getElementById('thoughtSection').scrollIntoView({ behavior: 'smooth', block: 'center' })
      })
    })
    
    // Сохранение мысли и показ практики
    document.getElementById('saveThought').addEventListener('click', function() {
      const thought = document.getElementById('practiceThought').value.trim()
      if (!thought) {
        alert('Напишите мысль для практики')
        return
      }
      
      // Обновляем текст предпросмотра
      document.getElementById('selectedThoughtPreview').textContent = `Мысль: "${thought}"`
      document.getElementById('selectedSignalName').textContent = `"${selectedSignalName}"`
      document.getElementById('selectedStrategyName').textContent = `"${selectedStrategyName}"`
      
      // Показываем шаг с практикой
      document.getElementById('practiceSection').style.display = 'block'
      
      // Прокручиваем к практике
      document.getElementById('practiceSection').scrollIntoView({ behavior: 'smooth', block: 'center' })
    })
    
    // Завершение практики
    document.getElementById('completeStopPractice').addEventListener('click', function() {
      // Получаем элемент рефлексии и показываем его
      const reflectionSection = document.getElementById('reflectionSection')
      if (reflectionSection) {
        reflectionSection.classList.remove('d-none')
        reflectionSection.scrollIntoView({ behavior: 'smooth' })
      }
      
      // Показываем кнопку завершения дня
      const completeDayBtn = document.getElementById('completeDay')
      if (completeDayBtn) {
        completeDayBtn.classList.remove('d-none')
      }
      
      // Можно также сохранить данные практики через fetch
      const thought = document.getElementById('practiceThought').value.trim()
      if (thought && selectedSignalName && selectedStrategyName) {
        fetch('/reflection_entries', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
          },
          body: JSON.stringify({
            entries: [{
              text: `Стоп-сигнал: ${selectedSignalName}\nСтратегия: ${selectedStrategyName}\nМысль: ${thought}`,
              category: 'День 8: Остановка мыслей'
            }]
          })
        }).catch(error => console.error('Error saving reflection:', error))
      }
    })
  })
</script>
<% end %>