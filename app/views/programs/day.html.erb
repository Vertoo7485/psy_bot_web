<div data-controller="day-program"
     data-day-program-program-id="<%= @program.id %>"
     data-day-program-day-number="<%= @day.day_number %>">

  <% day = @day %>
  <% content = day.content %>

  <div class="container py-4">
    <!-- Шапка дня -->
    <div class="row mb-4">
      <div class="col">
        <%= link_to program_path(@program), class: "btn btn-link text-secondary p-0 mb-3" do %>
          <i class="fas fa-arrow-left me-2"></i>К программе
        <% end %>
        
        <div class="d-flex justify-content-between align-items-center">
          <h2>День <%= day.day_number %>: <%= day.title %></h2>
          <span class="badge bg-primary fs-6">День <%= day.day_number %>/28</span>
        </div>
        <p class="text-secondary"><%= day.description %></p>
      </div>
    </div>

    <!-- Прогресс -->
    <div class="progress mb-4" style="height: 8px;">
      <div class="progress-bar bg-success" style="width: <%= (day.day_number.to_f / 28 * 100) %>%"></div>
    </div>

    <!-- Вступление -->
    <% if content["intro"].present? %>
      <div class="card mb-4">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-leaf text-success me-2"></i>
            <%= content["intro"]["title"] %>
          </h4>
          <p class="card-text"><%= content["intro"]["text"] %></p>
        </div>
      </div>
    <% end %>

    <!-- Научные факты -->
    <% if content["scientific_facts"].present? %>
      <div class="card mb-4">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-flask text-primary me-2"></i>
            Научные факты
          </h4>
          <div class="row">
            <% content["scientific_facts"].each do |fact| %>
              <div class="col-md-6 mb-3">
                <div class="d-flex">
                  <i class="fas fa-check-circle text-success me-3 mt-1"></i>
                  <div>
                    <p class="mb-1"><%= fact["fact"] %></p>
                    <small class="text-secondary"><%= fact["source"] %></small>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Преимущества -->
    <% if content["benefits"].present? %>
      <div class="card mb-4">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-star text-warning me-2"></i>
            Что вы получите
          </h4>
          <ul class="list-unstyled">
            <% content["benefits"].each do |benefit| %>
              <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i><%= benefit %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <!-- Упражнение -->
    <div class="card mb-4 border-primary">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0">
          <i class="fas fa-heartbeat me-2"></i>
          Практика дня
        </h4>
      </div>
      <div class="card-body">

        <!-- Техники дыхания (для дня 1) -->
        <% if content["exercise"] && content["exercise"]["techniques"].present? %>
          <h5 class="mt-4">Выберите технику дыхания:</h5>
          <div class="row">
            <% content["exercise"]["techniques"].each_with_index do |tech, index| %>
              <div class="col-md-6 mb-3">
                <div class="card h-100">
                  <div class="card-body">
                    <h6 class="card-title"><%= tech["name"] %></h6>
                    <p class="small text-secondary"><%= tech["description"] %></p>
                    <span class="badge bg-info"><%= tech["for_situation"] %></span>
                  </div>
                  <div class="card-footer bg-transparent">
                    <button class="btn btn-sm btn-outline-primary select-technique"
                            data-action="click->day-program#selectTechnique"
                            data-day-program-target="techniqueButtons"
                            data-technique="<%= index %>">
                      Выбрать
                    </button>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- Текстовая медитация (для дня 2) -->
        <% if content["text_meditation"].present? %>
          <div class="mt-4">
            <h5>Текстовая версия сканирования тела:</h5>
            <% content["text_meditation"].each do |part| %>
              <div class="mb-3 p-3 bg-light rounded">
                <h6><%= part["part"] %></h6>
                <p class="mb-0"><%= part["details"] %></p>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- Подготовка (для дня 2) -->
        <% if content["preparation"].present? %>
          <div class="mt-4 p-3 bg-light rounded">
            <h6>
              <i class="fas fa-clock me-2"></i>
              Подготовка к практике
            </h6>
            <p class="mb-2"><strong>Положение тела:</strong> <%= content["preparation"]["posture"] %></p>
            <p class="mb-2"><strong>Время и место:</strong> <%= content["preparation"]["timing"] %></p>
            <p><strong>Настройка:</strong></p>
            <ul>
              <% content["preparation"]["breathing"].each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Инструкции (для дня 2) -->
        <% if content["instructions"].present? %>
          <div class="mt-4">
            <h6>Маршрут сканирования:</h6>
            <ul>
              <% content["instructions"]["route"].each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
            
            <h6 class="mt-3">Что замечать:</h6>
            <ul>
              <% content["instructions"]["sensations"].each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
            
            <h6 class="mt-3">Установка ума:</h6>
            <ul>
              <% content["instructions"]["mindset"].each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Пошаговое упражнение благодарности (для дня 3) -->
        <% if content["exercise"] && content["exercise"]["steps"].present? %>
          <div class="mt-4">
            <h5 class="mb-3"><%= content["exercise"]["title"] %></h5>
            <p class="text-secondary mb-4"><%= content["exercise"]["description"] %></p>
            
            <% content["exercise"]["steps"].each_with_index do |step, index| %>
              <div class="card mb-3">
                <div class="card-body">
                  <h6 class="card-title">
                    <span class="badge bg-success me-2">Шаг <%= index + 1 %></span>
                    <%= step["category"] %>
                  </h6>
                  <div class="mb-3">
                    <small class="text-secondary">Подсказки:</small>
                    <ul class="mt-2">
                      <% step["questions"].each do |q| %>
                        <li><%= q %></li>
                      <% end %>
                    </ul>
                  </div>
                  <div class="mb-2">
                    <label class="form-label">Ваша благодарность:</label>
                    <textarea class="form-control gratitude-step-input" 
                              rows="2" 
                              data-step="<%= index %>"
                              placeholder="<%= step["placeholder"] %>"></textarea>
                  </div>
                </div>
              </div>
            <% end %>
            
            <div class="text-center mt-3">
              <button class="btn btn-success" id="saveGratitudeSteps">
                <i class="fas fa-save me-2"></i>Сохранить благодарности
              </button>
            </div>
          </div>
        <% end %>

        <!-- Таймер (для всех дней) -->
        <% if content["exercise"] && content["exercise"]["timer_options"].present? %>
          <div class="mt-4">
            <h5>Время практики:</h5>
            <div class="btn-group" role="group">
              <% content["exercise"]["timer_options"].each do |minutes| %>
                <button class="btn btn-outline-primary timer-option"
                        data-action="click->day-program#selectTimer"
                        data-day-program-target="timerButtons"
                        data-minutes="<%= minutes %>">
                  <%= minutes %> мин
                </button>
              <% end %>
            </div>
          </div>
        <% else %>
          <!-- Дефолтный таймер для всех дней -->
          <div class="mt-4">
            <h5>Время практики:</h5>
            <div class="btn-group" role="group">
              <button class="btn btn-outline-primary timer-option"
                      data-action="click->day-program#selectTimer"
                      data-day-program-target="timerButtons"
                      data-minutes="5">
                5 мин
              </button>
              <button class="btn btn-outline-primary timer-option"
                      data-action="click->day-program#selectTimer"
                      data-day-program-target="timerButtons"
                      data-minutes="10">
                10 мин
              </button>
              <button class="btn btn-outline-primary timer-option"
                      data-action="click->day-program#selectTimer"
                      data-day-program-target="timerButtons"
                      data-minutes="15">
                15 мин
              </button>
              <button class="btn btn-outline-primary timer-option"
                      data-action="click->day-program#selectTimer"
                      data-day-program-target="timerButtons"
                      data-minutes="20">
                20 мин
              </button>
              <button class="btn btn-outline-secondary timer-option"
                      data-action="click->day-program#selectTimer"
                      data-day-program-target="timerButtons"
                      data-minutes="custom">
                Свой вариант
              </button>
            </div>
          </div>
        <% end %>

        <!-- Кнопка начала практики (для дней с таймером) -->
        <% unless content["exercise"] && content["exercise"]["steps"].present? %>
          <div class="text-center mt-4">
            <button class="btn btn-success btn-lg px-5" 
                    id="startPractice"
                    data-action="click->day-program#startPractice">
              <i class="fas fa-play me-2"></i>Начать практику
            </button>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Рефлексия -->
    <% if content["reflection"].present? %>
      <div id="reflectionSection" class="card mb-4 d-none" data-day-program-target="reflection">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-pen me-2"></i>
            <%= content["reflection"]["title"] || "Рефлексия после практики" %>
          </h4>

          <div class="accordion" id="reflectionAccordion">
            <% if content["reflection"]["questions"].present? %>
              <% 
                russian_names = {
                  "feelings" => "О чувствах",
                  "process" => "О процессе",
                  "discoveries" => "Об открытиях",
                  "integration" => "Для жизни",
                  "mind" => "Об уме",
                  "body" => "О теле",
                  "difficulties" => "О сложностях",
                  "breath" => "О дыхании",
                  "questions" => "Вопросы"
                }
              %>
              <% content["reflection"]["questions"].each_with_index do |(key, questions), index| %>
                <% display_name = russian_names[key] || key.capitalize %>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button class="accordion-button <%= index == 0 ? '' : 'collapsed' %>" 
                            type="button" 
                            data-bs-toggle="collapse" 
                            data-bs-target="#collapse<%= key.capitalize %>">
                      <%= display_name %>
                    </button>
                  </h2>
                  <div id="collapse<%= key.capitalize %>" 
                       class="accordion-collapse collapse <%= index == 0 ? 'show' : '' %>" 
                       data-bs-parent="#reflectionAccordion">
                    <div class="accordion-body">
                      <ul class="list-unstyled">
                        <% questions.each do |q| %>
                          <li class="mb-2"><i class="fas fa-question-circle text-primary me-2"></i><%= q %></li>
                        <% end %>
                      </ul>
                    </div>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Трудности -->
    <% if content["challenges"].present? %>
      <div class="card mb-4">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-exclamation-triangle text-warning me-2"></i>
            Возможные трудности
          </h4>
          <div class="row">
            <% content["challenges"].each do |challenge| %>
              <div class="col-md-6 mb-3">
                <div class="card bg-light">
                  <div class="card-body">
                    <h6 class="card-title"><%= challenge["title"] %></h6>
                    <p class="small mb-0"><%= challenge["solution"] %></p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Советы на каждый день -->
    <% if content["daily_tips"].present? %>
      <div class="card mb-4">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-lightbulb text-info me-2"></i>
            Как использовать в жизни
          </h4>
          <div class="row">
            <% content["daily_tips"].each do |tip| %>
              <div class="col-md-6 mb-3">
                <div class="card bg-light">
                  <div class="card-body">
                    <h6 class="card-title"><%= tip["title"] %></h6>
                    <p class="small mb-0"><%= tip["description"] %></p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Завершение дня -->
    <div class="text-center mt-5">
      <button class="btn btn-success btn-lg px-5 d-none" 
              id="completeDay"
              data-action="click->day-program#completeDay">
        <i class="fas fa-check-circle me-2"></i>Завершить день
      </button>
      <p class="text-secondary mt-2 small">
        <i class="fas fa-clock me-1"></i>
        Следующий день будет доступен через 12 часов
      </p>
    </div>
  </div>
</div>

<!-- JavaScript для сохранения благодарностей -->
<script>
  document.getElementById('saveGratitudeSteps')?.addEventListener('click', function() {
    const inputs = document.querySelectorAll('.gratitude-step-input')
    const entries = []
    
    inputs.forEach(input => {
      if (input.value.trim()) {
        entries.push({ text: input.value.trim() })
      }
    })
    
    if (entries.length === 0) {
      alert('Напишите хотя бы одну благодарность')
      return
    }
    
    fetch('/gratitude_entries', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      },
      body: JSON.stringify({ entries: entries })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        alert('✅ Благодарности сохранены!')
        // Показываем рефлексию и кнопку завершения
        document.getElementById('reflectionSection').classList.remove('d-none')
        document.getElementById('completeDay').classList.remove('d-none')
        // Прокручиваем к рефлексии
        document.getElementById('reflectionSection').scrollIntoView({ behavior: 'smooth' })
      } else {
        alert('Ошибка: ' + data.error)
      }
    })
  })
</script>