<div data-controller="day-program"
     data-day-program-program-id="<%= @program.id %>"
     data-day-program-day-number="<%= @day.day_number %>">

  <% day = @day %>
  <% content = day.content %>

  <div class="container py-4">
    <!-- Шапка дня -->
    <div class="row mb-4">
      <div class="col">
        <%= link_to program_path(@program), class: "btn btn-link text-secondary p-0 mb-3" do %>
          <i class="fas fa-arrow-left me-2"></i>К программе
        <% end %>
        
        <div class="d-flex justify-content-between align-items-center">
          <h2>День <%= day.day_number %>: <%= day.title %></h2>
          <span class="badge bg-primary fs-6">День <%= day.day_number %>/28</span>
        </div>
        <p class="text-secondary"><%= day.description %></p>
      </div>
    </div>

    <!-- Прогресс -->
    <div class="progress mb-4" style="height: 8px;">
      <div class="progress-bar bg-success" style="width: <%= (day.day_number.to_f / 28 * 100) %>%"></div>
    </div>

    <!-- Вступление -->
    <% if content["intro"].present? %>
      <div class="card mb-4">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-leaf text-success me-2"></i>
            <%= content["intro"]["title"] %>
          </h4>
          <p class="card-text"><%= content["intro"]["text"] %></p>
        </div>
      </div>
    <% end %>

    <!-- Общие компоненты -->
    <%= render 'programs/shared/scientific_facts', content: content %>
    <%= render 'programs/shared/benefits', content: content %>

    <!-- Упражнение -->
    <div class="card mb-4 border-primary">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0">
          <i class="fas fa-heartbeat me-2"></i>
          Практика дня
        </h4>
      </div>
      <div class="card-body">

        <!-- Техники (дни 1,4) -->
        <% if day_has_techniques?(day.day_number) %>
          <%= render 'programs/shared/techniques', day: day, content: content %>
        <% end %>

        <!-- Выбор активности (день 5) -->
        <% if day_has_activity_selection?(day.day_number) && content["exercise"]["activity_types"].present? %>
          <%= render 'programs/shared/selection_cards', 
              items: content["exercise"]["activity_types"], 
              item_type: "activity",
              target: "activityButtons",
              action: "selectActivity" %>
        <% end %>

        <!-- Выбор отдыха (день 6) -->
        <% if day_has_rest_selection?(day.day_number) && content["exercise"]["rest_types"].present? %>
          <%= render 'programs/shared/selection_cards', 
              items: content["exercise"]["rest_types"], 
              item_type: "rest",
              target: "restButtons",
              action: "selectRest" %>
        <% end %>

        <!-- День 8: Стоп-сигналы -->
        <% if day_has_stop_signal?(day.day_number) && content["exercise"]["stop_signals"].present? %>
          <%= render 'programs/shared/selection_cards', 
              items: content["exercise"]["stop_signals"], 
              item_type: "signal",
              target: "signalButtons",
              action: "selectSignal" %>
        <% end %>

        <!-- День 8: Стратегии переключения -->
        <% if day_has_stop_signal?(day.day_number) && content["exercise"]["distraction_strategies"].present? %>
          <div class="card mb-4" id="strategySection" style="display: none;">
            <div class="card-header bg-primary text-white">
              <h6 class="mb-0">Шаг 2: Выберите стратегию переключения</h6>
            </div>
            <div class="card-body">
              <%= render 'programs/shared/selection_cards', 
                  items: content["exercise"]["distraction_strategies"], 
                  item_type: "strategy",
                  target: "strategyButtons",
                  action: "selectStrategy" %>
            </div>
          </div>
        <% end %>

        <!-- День 2: Текстовая медитация -->
        <% if content["text_meditation"].present? %>
          <div class="mt-4">
            <h5>Текстовая версия сканирования тела:</h5>
            <% content["text_meditation"].each do |part| %>
              <div class="mb-3 p-3 bg-light rounded">
                <h6><%= part["part"] %></h6>
                <p class="mb-0"><%= part["details"] %></p>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- День 3: Благодарность -->
        <% if day_is_gratitude?(day.day_number) %>
          <%= render 'day_3_gratitude', content: content %>
        <% end %>

        <!-- День 7: Рефлексия недели -->
        <% if day_is_reflection_week?(day.day_number) %>
          <%= render 'day_7_reflection', content: content %>
        <% end %>

        <!-- День 8: Ввод мысли -->
        <% if day_has_stop_signal?(day.day_number) %>
          <%= render 'day_8_thought_input' %>
        <% end %>

        <!-- Таймер -->
        <% if day_has_timer?(day.day_number) %>
          <%= render 'programs/shared/timer', day: day, content: content %>
        <% end %>

      </div>
    </div>

    <!-- Рефлексия (общая) -->
    <%= render 'programs/shared/reflection', content: content %>

    <!-- День 5: Выбор настроения -->
    <% if day.day_number == 5 && content["mood_options"].present? %>
      <%= render 'day_5_mood_selection', content: content %>
    <% end %>

    <!-- День 6: Выбор состояния -->
    <% if day.day_number == 6 && content["state_options"].present? %>
      <%= render 'day_6_state_selection', content: content %>
    <% end %>

    <!-- День 9: Когнитивный анализ -->
    <% if day.day_number == 9 %>
      <%= render 'day_9_cognitive_analysis', content: content %>
      <%= render 'day_9_script' %>
    <% end %>

    <!-- День 10: Дневник эмоций -->
    <% if day.day_number == 10 %>
      <%= render 'day_10_emotion_diary', content: content %>
      <%= render 'day_10_script' %>
    <% end %>

    <!-- День 11: Техника заземления -->
    <% if day.day_number == 11 %>
      <%= render 'day_11_grounding', content: content %>
      <%= render 'day_11_script', content: content %>
    <% end %>

    <!-- День 12: Практика самосострадания -->
    <% if day.day_number == 12 %>
      <%= render 'day_12_self_compassion', content: content %>
      <%= render 'day_12_script', content: content %>
    <% end %>

    <!-- Трудности и советы -->
    <%= render 'programs/shared/challenges', content: content %>
    <%= render 'programs/shared/daily_tips', content: content %>

    <!-- Завершение дня -->
    <div class="text-center mt-5">
      <button class="btn btn-success btn-lg px-5 d-none" 
              id="completeDay"
              data-action="click->day-program#completeDay">
        <i class="fas fa-check-circle me-2"></i>Завершить день
      </button>
      <p class="text-secondary mt-2 small">
        <i class="fas fa-clock me-1"></i>
        Следующий день будет доступен через 12 часов
      </p>
    </div>
  </div>
</div>

<!-- Стили -->
<%= render 'programs/shared/styles' %>

<!-- Скрипты для специальных дней -->
<%= render 'day_3_script', content: content if day_is_gratitude?(day.day_number) %>
<%= render 'day_7_script', content: content if day_is_reflection_week?(day.day_number) %>
<%= render 'day_8_script', content: content if day_has_stop_signal?(day.day_number) %>