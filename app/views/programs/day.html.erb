  .rest-card .card-body {
    max-height: none;
    overflow: visible;
  }
  
  .activity-card .badge,
  .rest-card .badge {
    white-space: normal;
    word-wrap: break-word;
    text-align: left;
    line-height: 1.4;
    padding: 0.5rem;
    margin-bottom: 0.5rem;
    width: 100%;
  }
  
  .activity-card .d-flex,
  .rest-card .d-flex {
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .activity-card .badge.bg-info,
  .activity-card .badge.bg-success,
  .rest-card .badge.bg-info,
  .rest-card .badge.bg-success {
    display: block;
    width: 100%;
    font-size: 0.85rem;
  }
  
  @media (min-width: 768px) {
    .activity-card .d-flex,
    .rest-card .d-flex {
      flex-direction: row;
      flex-wrap: wrap;
    }
    
    .activity-card .badge,
    .rest-card .badge {
      width: auto;
      flex: 1 1 auto;
    }
  }

  /* Убедимся, что кнопки кликабельны */
  .activity-card .card-footer,
  .rest-card .card-footer {
    position: relative;
    z-index: 10;
    background: transparent;
    border-top: 1px solid rgba(0,0,0,0.125);
    padding: 0.75rem;
  }
  
  .activity-card .btn,
  .rest-card .btn {
    position: relative;
    z-index: 20;
    pointer-events: auto;
    cursor: pointer;
  }
  
