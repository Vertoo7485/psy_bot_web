<div data-controller="day-program"
     data-day-program-program-id="<%= @program.id %>"
     data-day-program-day-number="<%= @day.day_number %>">

  <% day = @day %>
  <% content = day.content %>

  <div class="container py-4">
    <!-- Шапка дня -->
    <div class="row mb-4">
      <div class="col">
        <%= link_to program_path(@program), class: "btn btn-link text-secondary p-0 mb-3" do %>
          <i class="fas fa-arrow-left me-2"></i>К программе
        <% end %>
        
        <div class="d-flex justify-content-between align-items-center">
          <h2>День <%= day.day_number %>: <%= day.title %></h2>
          <span class="badge bg-primary fs-6">День <%= day.day_number %>/28</span>
        </div>
        <p class="text-secondary"><%= day.description %></p>
      </div>
    </div>

    <!-- Прогресс -->
    <div class="progress mb-4" style="height: 8px;">
      <div class="progress-bar bg-success" style="width: <%= (day.day_number.to_f / 28 * 100) %>%"></div>
    </div>

    <!-- Вступление -->
    <% if content["intro"].present? %>
      <div class="card mb-4">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-leaf text-success me-2"></i>
            <%= content["intro"]["title"] %>
          </h4>
          <p class="card-text"><%= content["intro"]["text"] %></p>
        </div>
      </div>
    <% end %>

    <!-- Научные факты -->
    <% if content["scientific_facts"].present? %>
      <div class="card mb-4">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-flask text-primary me-2"></i>
            Научные факты
          </h4>
          <div class="row">
            <% content["scientific_facts"].each do |fact| %>
              <div class="col-md-6 mb-3">
                <div class="d-flex">
                  <i class="fas fa-check-circle text-success me-3 mt-1"></i>
                  <div>
                    <p class="mb-1"><%= fact["fact"] %></p>
                    <small class="text-secondary"><%= fact["source"] %></small>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Преимущества -->
    <% if content["benefits"].present? %>
      <div class="card mb-4">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-star text-warning me-2"></i>
            Что вы получите
          </h4>
          <ul class="list-unstyled">
            <% content["benefits"].each do |benefit| %>
              <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i><%= benefit %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <!-- Упражнение -->
    <div class="card mb-4 border-primary">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0">
          <i class="fas fa-heartbeat me-2"></i>
          Практика дня
        </h4>
      </div>
      <div class="card-body">

        <!-- Техники (дыхания для дня 1, наблюдения для дня 4) -->
        <% if content["exercise"] && content["exercise"]["techniques"].present? %>
          <h5 class="mt-4">
            <% if day.day_number == 4 %>
              Выберите технику наблюдения:
            <% else %>
              Выберите технику дыхания:
            <% end %>
          </h5>
          <div class="row">
            <% content["exercise"]["techniques"].each_with_index do |tech, index| %>
              <div class="col-md-6 mb-3">
                <div class="card h-100">
                  <div class="card-body">
                    <h6 class="card-title"><%= tech["name"] %></h6>
                    <p class="small text-secondary"><%= tech["description"] %></p>
                    <span class="badge bg-info"><%= tech["for_situation"] %></span>
                  </div>
                  <div class="card-footer bg-transparent">
                    <button class="btn btn-sm btn-outline-primary select-technique"
                            data-action="click->day-program#selectTechnique"
                            data-day-program-target="techniqueButtons"
                            data-technique="<%= index %>">
                      Выбрать
                    </button>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- Типы активности (для дня 5) -->
        <% if day.day_number == 5 && content["exercise"]["activity_types"].present? %>
          <div class="mt-4">
            <h5>Выберите тип активности:</h5>
            <div class="row">
              <% content["exercise"]["activity_types"].each_with_index do |activity, index| %>
                <div class="col-md-6 mb-3">
                  <div class="card h-100 activity-card" data-activity="<%= index %>">
                    <div class="card-body">
                      <h6 class="card-title"><%= activity["name"] %></h6>
                      <p class="small text-secondary"><%= activity["description"] %></p>
                      <div class="d-flex justify-content-between align-items-center mt-2">
                        <span class="badge bg-info">Интенсивность: <%= activity["intensity"] %></span>
                        <span class="badge bg-success">Польза: <%= activity["benefits"] %></span>
                      </div>
                    </div>
                    <div class="card-footer bg-transparent">
                      <button class="btn btn-sm btn-outline-primary select-activity"
                              data-action="click->day-program#selectActivity"
                              data-day-program-target="activityButtons"
                              data-activity="<%= index %>">
                        Выбрать
                      </button>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Типы отдыха (для дня 6) -->
        <% if day.day_number == 6 && content["exercise"]["rest_types"].present? %>
          <div class="mt-4">
            <h5>Выберите тип отдыха:</h5>
            <div class="row">
              <% content["exercise"]["rest_types"].each_with_index do |rest, index| %>
                <div class="col-md-6 mb-3">
                  <div class="card h-100 rest-card" data-rest="<%= index %>">
                    <div class="card-body">
                      <h6 class="card-title"><%= rest["name"] %></h6>
                      <p class="small text-secondary"><%= rest["description"] %></p>
                      <div class="d-flex justify-content-between align-items-center mt-2">
                        <span class="badge bg-info">Время: <%= rest["duration"] %></span>
                        <span class="badge bg-success">Польза: <%= rest["benefits"] %></span>
                      </div>
                    </div>
                    <div class="card-footer bg-transparent">
                      <button class="btn btn-sm btn-outline-primary select-rest"
                              data-action="click->day-program#selectRest"
                              data-day-program-target="restButtons"
                              data-rest="<%= index %>">
                        Выбрать
                      </button>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- День 8: Техника «Остановка мыслей» (упрощенный) -->
        <% if day.day_number == 8 && content["exercise"].present? %>
          <div class="mt-4">
            <h5 class="mb-3">🛑 Техника «Остановка мыслей»</h5>
            <p class="text-secondary mb-4"><%= content["exercise"]["description"] %></p>
            
            <!-- Шаг 1: Выбор стоп-сигнала -->
            <div class="card mb-4">
              <div class="card-header bg-primary text-white">
                <h6 class="mb-0">Шаг 1: Выберите стоп-сигнал</h6>
              </div>
              <div class="card-body">
                <div class="row">
                  <% content["exercise"]["stop_signals"].each_with_index do |signal, index| %>
                    <div class="col-md-6 mb-3">
                      <div class="card h-100 signal-card" data-signal="<%= index %>">
                        <div class="card-body">
                          <h6 class="card-title"><%= signal["name"] %></h6>
                          <p class="small text-secondary"><%= signal["description"] %></p>
                          <button class="btn btn-sm btn-outline-primary select-signal w-100 mt-2"
                                  data-action="click->day-program#selectSignal"
                                  data-day-program-target="signalButtons"
                                  data-signal="<%= index %>">
                            Выбрать
                          </button>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
            
            <!-- Шаг 2: Выбор стратегии переключения (скрыт до выбора сигнала) -->
            <div class="card mb-4" id="strategySection" style="display: none;">
              <div class="card-header bg-primary text-white">
                <h6 class="mb-0">Шаг 2: Выберите стратегию переключения</h6>
              </div>
              <div class="card-body">
                <div class="row">
                  <% content["exercise"]["distraction_strategies"].each_with_index do |strategy, index| %>
                    <div class="col-md-6 mb-3">
                      <div class="card h-100 strategy-card" data-strategy="<%= index %>">
                        <div class="card-body">
                          <h6 class="card-title"><%= strategy["name"] %></h6>
                          <p class="small text-secondary"><%= strategy["description"] %></p>
                          <span class="badge bg-info mb-2">⏱️ <%= strategy["duration"] %></span>
                          <button class="btn btn-sm btn-outline-primary select-strategy w-100 mt-2"
                                  data-action="click->day-program#selectStrategy"
                                  data-day-program-target="strategyButtons"
                                  data-strategy="<%= index %>">
                            Выбрать
                          </button>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
            
            <!-- Шаг 3: Ввод мысли (скрыт до выбора стратегии) -->
            <div class="card mb-4" id="thoughtSection" style="display: none;">
              <div class="card-header bg-primary text-white">
                <h6 class="mb-0">Шаг 3: Напишите мысль для практики</h6>
              </div>
              <div class="card-body">
                <div class="alert alert-light">
                  <small>💡 Рекомендации:</small>
                  <ul class="mt-2 mb-0 small">
                    <% if content["exercise"]["thought_guidance"]["beginner"].present? %>
                      <% content["exercise"]["thought_guidance"]["beginner"].each do |tip| %>
                        <li>✅ <%= tip %></li>
                      <% end %>
                    <% end %>
                    <li class="text-danger">⚠️ Не начинайте с самых трудных мыслей</li>
                  </ul>
                </div>
                <textarea class="form-control" id="practiceThought" rows="3" placeholder="Например: 'Что я буду есть на ужин?' или 'Не опоздаю ли я на встречу?'"></textarea>
                <div class="text-end mt-3">
                  <button class="btn btn-success" id="saveThought">Готово, сохранить мысль</button>
                </div>
              </div>
            </div>
            
            <!-- Шаг 4: Выполнение практики (показывается после сохранения мысли) -->
            <div class="card mb-4" id="practiceSection" style="display: none;">
              <div class="card-header bg-success text-white">
                <h6 class="mb-0">Шаг 4: Выполните практику</h6>
              </div>
              <div class="card-body text-center">
                <p id="selectedThoughtPreview" class="fw-bold mb-3"></p>
                
                <div class="alert alert-info">
                  <p class="mb-2"><strong>Алгоритм:</strong></p>
                  <p class="mb-1">1. Позвольте мысли появиться (5-10 сек)</p>
                  <p class="mb-1">2. Примените стоп-сигнал <span id="selectedSignalName"></span></p>
                  <p class="mb-1">3. Сразу переключитесь на <span id="selectedStrategyName"></span></p>
                  <p class="mb-0">4. Практикуйте 2-3 минуты</p>
                </div>
                
                <div class="mt-4">
                  <button class="btn btn-success btn-lg px-5" id="completeStopPractice">
                    <i class="fas fa-check-circle me-2"></i>Я выполнил практику
                  </button>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Текстовая медитация (для дня 2) -->
        <% if content["text_meditation"].present? %>
          <div class="mt-4">
            <h5>Текстовая версия сканирования тела:</h5>
            <% content["text_meditation"].each do |part| %>
              <div class="mb-3 p-3 bg-light rounded">
                <h6><%= part["part"] %></h6>
                <p class="mb-0"><%= part["details"] %></p>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- Подготовка (для дня 2) -->
        <% if content["preparation"].present? && !content["exercise"]["activity_types"].present? %>
          <div class="mt-4 p-3 bg-light rounded">
            <h6>
              <i class="fas fa-clock me-2"></i>
              Подготовка к практике
            </h6>
            <% if content["preparation"]["posture"].present? %>
              <p class="mb-2"><strong>Положение тела:</strong> <%= content["preparation"]["posture"] %></p>
            <% end %>
            <% if content["preparation"]["timing"].present? %>
              <p class="mb-2"><strong>Время и место:</strong> <%= content["preparation"]["timing"] %></p>
            <% end %>
            <% if content["preparation"]["breathing"].present? %>
              <p><strong>Настройка:</strong></p>
              <ul>
                <% content["preparation"]["breathing"].each do |item| %>
                  <li><%= item %></li>
                <% end %>
              </ul>
            <% end %>
          </div>
        <% end %>

        <!-- Подготовка для дня 5 -->
        <% if day.day_number == 5 && content["exercise"]["preparation"].present? %>
          <div class="mt-4 p-3 bg-light rounded">
            <h6>
              <i class="fas fa-clock me-2"></i>
              Подготовка к практике
            </h6>
            <p class="mb-2"><strong>Экипировка:</strong> <%= content["exercise"]["preparation"]["equipment"] %></p>
            <p class="mb-2"><strong>Пространство:</strong> <%= content["exercise"]["preparation"]["space"] %></p>
            <p><strong>Установка:</strong></p>
            <ul>
              <% content["exercise"]["preparation"]["guidance"].each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Инструкции (для дня 2) -->
        <% if content["instructions"].present? %>
          <div class="mt-4">
            <h6>Маршрут сканирования:</h6>
            <ul>
              <% content["instructions"]["route"].each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
            
            <h6 class="mt-3">Что замечать:</h6>
            <ul>
              <% content["instructions"]["sensations"].each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
            
            <h6 class="mt-3">Установка ума:</h6>
            <ul>
              <% content["instructions"]["mindset"].each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Пошаговое упражнение благодарности (для дня 3) -->
        <% if content["exercise"] && content["exercise"]["steps"].present? %>
          <div class="mt-4">
            <h5 class="mb-3"><%= content["exercise"]["title"] %></h5>
            <p class="text-secondary mb-4"><%= content["exercise"]["description"] %></p>
            
            <% content["exercise"]["steps"].each_with_index do |step, index| %>
              <div class="card mb-3">
                <div class="card-body">
                  <h6 class="card-title">
                    <span class="badge bg-success me-2">Шаг <%= index + 1 %></span>
                    <%= step["category"] %>
                  </h6>
                  <div class="mb-3">
                    <small class="text-secondary">Подсказки:</small>
                    <ul class="mt-2">
                      <% step["questions"].each do |q| %>
                        <li><%= q %></li>
                      <% end %>
                    </ul>
                  </div>
                  <div class="mb-2">
                    <label class="form-label">Ваша благодарность:</label>
                    <textarea class="form-control gratitude-step-input" 
                              rows="2" 
                              data-step="<%= index %>"
                              placeholder="<%= step["placeholder"] %>"></textarea>
                  </div>
                </div>
              </div>
            <% end %>
            
            <div class="text-center mt-3">
              <button class="btn btn-success" id="saveGratitudeSteps">
                <i class="fas fa-save me-2"></i>Сохранить благодарности
              </button>
            </div>
          </div>
        <% end %>

        <!-- Таймер (для всех дней, кроме дня 3, 7 и 8) -->
        <% if day.day_number != 3 && day.day_number != 7 && day.day_number != 8 %>
          <div class="mt-4">
            <h5>Время практики:</h5>
            <div class="btn-group" role="group">
              <% if content["exercise"] && content["exercise"]["timer_options"].present? %>
                <% content["exercise"]["timer_options"].each do |minutes| %>
                  <button class="btn btn-outline-primary timer-option"
                          data-action="click->day-program#selectTimer"
                          data-day-program-target="timerButtons"
                          data-minutes="<%= minutes %>">
                    <%= minutes %> мин
                  </button>
                <% end %>
              <% else %>
                <!-- Дефолтные значения для всех дней -->
                <button class="btn btn-outline-primary timer-option"
                        data-action="click->day-program#selectTimer"
                        data-day-program-target="timerButtons"
                        data-minutes="5">
                  5 мин
                </button>
                <button class="btn btn-outline-primary timer-option"
                        data-action="click->day-program#selectTimer"
                        data-day-program-target="timerButtons"
                        data-minutes="10">
                  10 мин
                </button>
                <button class="btn btn-outline-primary timer-option"
                        data-action="click->day-program#selectTimer"
                        data-day-program-target="timerButtons"
                        data-minutes="15">
                  15 мин
                </button>
                <button class="btn btn-outline-primary timer-option"
                        data-action="click->day-program#selectTimer"
                        data-day-program-target="timerButtons"
                        data-minutes="20">
                  20 мин
                </button>
              <% end %>
              <button class="btn btn-outline-secondary timer-option"
                      data-action="click->day-program#selectTimer"
                      data-day-program-target="timerButtons"
                      data-minutes="custom">
                Свой вариант
              </button>
            </div>
          </div>

          <!-- Кнопка начала практики (для дней с таймером) -->
          <div class="text-center mt-4">
            <button class="btn btn-success btn-lg px-5" 
                    id="startPractice"
                    data-action="click->day-program#startPractice">
              <i class="fas fa-play me-2"></i>Начать практику
            </button>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Рефлексия -->
    <% if content["reflection"].present? %>
      <div id="reflectionSection" class="card mb-4 d-none" data-day-program-target="reflection">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-pen me-2"></i>
            <%= content["reflection"]["title"] || "Рефлексия после практики" %>
          </h4>

          <div class="accordion" id="reflectionAccordion">
            <% if content["reflection"]["questions"].present? %>
              <% 
                russian_names = {
                  "feelings" => "О чувствах",
                  "process" => "О процессе",
                  "discoveries" => "Об открытиях",
                  "integration" => "Для жизни",
                  "mind" => "Об уме",
                  "body" => "О теле",
                  "difficulties" => "О сложностях",
                  "breath" => "О дыхании",
                  "visual" => "О зрении",
                  "mood" => "О настроении",
                  "energy" => "Об энергии",
                  "stop" => "Об остановке",
                  "distraction" => "О переключении",
                  "effect" => "Об эффекте",
                  "questions" => "Вопросы"
                }
              %>
              <% content["reflection"]["questions"].each_with_index do |(key, questions), index| %>
                <% display_name = russian_names[key] || key.capitalize %>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button class="accordion-button <%= index == 0 ? '' : 'collapsed' %>" 
                            type="button" 
                            data-bs-toggle="collapse" 
                            data-bs-target="#collapse<%= key.capitalize %>">
                      <%= display_name %>
                    </button>
                  </h2>
                  <div id="collapse<%= key.capitalize %>" 
                       class="accordion-collapse collapse <%= index == 0 ? 'show' : '' %>" 
                       data-bs-parent="#reflectionAccordion">
                    <div class="accordion-body">
                      <ul class="list-unstyled">
                        <% questions.each do |q| %>
                          <li class="mb-2"><i class="fas fa-question-circle text-primary me-2"></i><%= q %></li>
                        <% end %>
                      </ul>
                    </div>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Выбор настроения для дня 5 -->
    <% if day.day_number == 5 && content["mood_options"].present? %>
      <div class="mt-4" id="moodSelection" style="display: none;">
        <h5 class="mb-3">Как изменилось ваше настроение?</h5>
        <p class="text-secondary small mb-3">Ваш ответ поможет отслеживать связь между движением и эмоциональным состоянием</p>
        
        <div class="btn-group-vertical w-100" role="group">
          <div class="card mb-2">
            <div class="card-body p-3">
              <div class="d-flex align-items-start">
                <button class="btn btn-outline-primary mood-option me-3"
                        data-action="click->day-program#selectMood"
                        data-day-program-target="moodButtons"
                        data-mood="0"
                        style="min-width: 50px;">
                  😊
                </button>
                <div>
                  <h6 class="mb-1">Значительно лучше</h6>
                  <p class="small text-secondary mb-0">Движение дало заметный прилив энергии и позитива. Отличный результат!</p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="card mb-2">
            <div class="card-body p-3">
              <div class="d-flex align-items-start">
                <button class="btn btn-outline-primary mood-option me-3"
                        data-action="click->day-program#selectMood"
                        data-day-program-target="moodButtons"
                        data-mood="1"
                        style="min-width: 50px;">
                  🙂
                </button>
                <div>
                  <h6 class="mb-1">Немного лучше</h6>
                  <p class="small text-secondary mb-0">Небольшое улучшение — хороший знак. Даже легкое движение влияет на состояние.</p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="card mb-2">
            <div class="card-body p-3">
              <div class="d-flex align-items-start">
                <button class="btn btn-outline-primary mood-option me-3"
                        data-action="click->day-program#selectMood"
                        data-day-program-target="moodButtons"
                        data-mood="2"
                        style="min-width: 50px;">
                  😐
                </button>
                <div>
                  <h6 class="mb-1">Без изменений</h6>
                  <p class="small text-secondary mb-0">Тоже нормально! Иногда движение работает как поддержание, а не как улучшение.</p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="card mb-2">
            <div class="card-body p-3">
              <div class="d-flex align-items-start">
                <button class="btn btn-outline-primary mood-option me-3"
                        data-action="click->day-program#selectMood"
                        data-day-program-target="moodButtons"
                        data-mood="3"
                        style="min-width: 50px;">
                  😔
                </button>
                <div>
                  <h6 class="mb-1">Хуже (усталость)</h6>
                  <p class="small text-secondary mb-0">Возможно, нагрузка была великовата. В следующий раз попробуйте более легкую активность.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <p class="text-secondary small mt-3 text-center">
          <i class="fas fa-info-circle me-1"></i>
          Ваш выбор никуда не передается — только для вашей личной статистики
        </p>
      </div>
    <% end %>

    <!-- Выбор состояния для дня 6 -->
    <% if day.day_number == 6 && content["state_options"].present? %>
      <div class="mt-4" id="stateSelection" style="display: none;">
        <h5 class="mb-3">Как изменилось ваше состояние после отдыха?</h5>
        <p class="text-secondary small mb-3">Ваш ответ поможет понять, какой отдых лучше всего восстанавливает</p>
        
        <div class="btn-group-vertical w-100" role="group">
          <% content["state_options"].each_with_index do |state, index| %>
            <% 
              if state.is_a?(String)
                emoji = state.match(/[😊🙂😐😔😌😴🎨📚🎵🛀💤]/)&.[](0) || "😊"
                text = state
              else
                emoji = state["emoji"] || "😊"
                text = "#{state['title']} — #{state['description']}"
              end
            %>
            <div class="card mb-2">
              <div class="card-body p-3">
                <div class="d-flex align-items-start">
                  <button class="btn btn-outline-primary state-option me-3"
                          data-action="click->day-program#selectState"
                          data-day-program-target="stateButtons"
                          data-state="<%= index %>"
                          style="min-width: 50px;">
                    <%= emoji %>
                  </button>
                  <div>
                    <h6 class="mb-1"><%= state.is_a?(String) ? state : state['title'] %></h6>
                    <p class="small text-secondary mb-0">
                      <%= state.is_a?(String) ? "Выберите этот вариант" : state['description'] %>
                    </p>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        
        <p class="text-secondary small mt-3 text-center">
          <i class="fas fa-info-circle me-1"></i>
          Это поможет вам отслеживать, какой отдых лучше всего восстанавливает
        </p>
      </div>
    <% end %>

    <!-- День 7: Рефлексия недели -->
    <% if day.day_number == 7 && content["reflection_categories"].present? %>
      <div class="mt-4">
        <h5 class="mb-3">📝 Рефлексия первой недели</h5>
        <p class="text-secondary mb-4">Ответьте на вопросы в каждой категории. Это поможет осмыслить и закрепить опыт.</p>
        
        <div class="progress mb-4" id="reflectionProgress" style="height: 10px;">
          <div class="progress-bar bg-success" style="width: 0%"></div>
        </div>
        
        <div id="reflectionCategories">
          <% content["reflection_categories"].each_with_index do |category, index| %>
            <div class="card mb-4 reflection-category" data-category="<%= index %>" style="<%= index > 0 ? 'display: none;' : '' %>">
              <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                  <%= category["emoji"] %> <%= category["name"] %>
                  <span class="badge bg-light text-dark float-end">Категория <%= index + 1 %>/4</span>
                </h5>
              </div>
              <div class="card-body">
                <p class="lead"><%= category["prompt"] %></p>
                
                <div class="alert alert-light mb-4">
                  <small>💡 Подсказки:</small>
                  <ul class="mt-2 mb-0">
                    <% category["questions"].each do |q| %>
                      <li><%= q %></li>
                    <% end %>
                  </ul>
                </div>
                
                <div class="mb-3">
                  <label class="form-label">Ваш ответ:</label>
                  <textarea class="form-control reflection-input" 
                            rows="4" 
                            data-category="<%= index %>"
                            placeholder="Напишите ваши мысли..."></textarea>
                </div>
                
                <div class="text-end">
                  <button class="btn btn-success save-reflection" data-category="<%= index %>">
                    Сохранить и продолжить
                  </button>
                  <button class="btn btn-link text-secondary skip-reflection" data-category="<%= index %>">
                    Пропустить
                  </button>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        
        <div id="reflectionComplete" style="display: none;">
          <div class="alert alert-success text-center">
            <h5 class="mb-3">✅ Рефлексия завершена!</h5>
            <p>Спасибо, что уделили время осмыслению первой недели.</p>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Трудности -->
    <% if content["challenges"].present? %>
      <div class="card mb-4">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-exclamation-triangle text-warning me-2"></i>
            Возможные трудности
          </h4>
          <div class="row">
            <% content["challenges"].each do |challenge| %>
              <div class="col-md-6 mb-3">
                <div class="card bg-light">
                  <div class="card-body">
                    <h6 class="card-title"><%= challenge["title"] %></h6>
                    <p class="small mb-0"><%= challenge["solution"] %></p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Советы на каждый день -->
    <% if content["daily_tips"].present? %>
      <div class="card mb-4">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-lightbulb text-info me-2"></i>
            Как использовать в жизни
          </h4>
          <div class="row">
            <% content["daily_tips"].each do |tip| %>
              <div class="col-md-6 mb-3">
                <div class="card bg-light">
                  <div class="card-body">
                    <h6 class="card-title"><%= tip["title"] %></h6>
                    <p class="small mb-0"><%= tip["description"] %></p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Завершение дня -->
    <div class="text-center mt-5">
      <button class="btn btn-success btn-lg px-5 d-none" 
              id="completeDay"
              data-action="click->day-program#completeDay">
        <i class="fas fa-check-circle me-2"></i>Завершить день
      </button>
      <p class="text-secondary mt-2 small">
        <i class="fas fa-clock me-1"></i>
        Следующий день будет доступен через 12 часов
      </p>
    </div>
  </div>

  <style>
