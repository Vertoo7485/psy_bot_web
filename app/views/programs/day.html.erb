<div data-controller="day-program"
     data-day-program-program-id="<%= @program.id %>"
     data-day-program-day-number="<%= @day.day_number %>">

  <% day = @day %>
  <% content = day.content %>

  <div class="container py-4">
    <!-- Шапка дня -->
    <div class="row mb-4">
      <div class="col">
        <%= link_to program_path(@program), class: "btn btn-link text-secondary p-0 mb-3" do %>
          <i class="fas fa-arrow-left me-2"></i>К программе
        <% end %>
        
        <div class="d-flex justify-content-between align-items-center">
          <h2>День <%= day.day_number %>: <%= day.title %></h2>
          <span class="badge bg-primary fs-6">День <%= day.day_number %>/<%= @program.days.count %></span>
        </div>
        <p class="text-secondary"><%= day.description %></p>
      </div>
    </div>

    <!-- Прогресс -->
    <div class="progress mb-4" style="height: 8px;">
      <div class="progress-bar bg-success" style="width: <%= (day.day_number.to_f / @program.days.count * 100) %>%"></div>
    </div>

    <!-- Специальный рендеринг для программы 14 дней -->
    <% if @program.days.count == 14 %>
      
      <!-- Вступление -->
      <div class="card mb-4">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-info-circle text-primary me-2"></i>
            <%= content["intro"]["title"] %>
          </h4>
          <p class="card-text"><%= content["intro"]["text"] %></p>
        </div>
      </div>

      <!-- Упражнение -->
      <div class="card mb-4 border-primary">
        <div class="card-header bg-primary text-white">
          <h4 class="mb-0">
            <i class="fas fa-heartbeat me-2"></i>
            Практика дня
          </h4>
        </div>
        <div class="card-body">
          <h5><%= content["exercise"]["title"] %></h5>
          <p class="lead"><%= content["exercise"]["description"] %></p>
          
          <!-- Пошаговая инструкция -->
          <% if content["exercise"]["steps"] %>
            <div class="mt-4">
              <h6>📋 Пошаговая инструкция:</h6>
              <ol class="mt-3">
                <% content["exercise"]["steps"].each do |step| %>
                  <li class="mb-2"><%= step %></li>
                <% end %>
              </ol>
            </div>
          <% end %>
          
          <!-- Вопросы для размышления -->
          <% if content["exercise"]["questions"] %>
            <div class="mt-4">
              <h6>🤔 Вопросы для размышления:</h6>
              <ul class="mt-3">
                <% content["exercise"]["questions"].each do |q| %>
                  <li class="mb-2"><%= q %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          
          <!-- Зоны для сканирования -->
          <% if content["exercise"]["zones"] %>
            <div class="mt-4">
              <h6>🔍 Зоны для сканирования:</h6>
              <ol class="mt-3">
                <% content["exercise"]["zones"].each do |zone| %>
                  <li class="mb-2"><%= zone %></li>
                <% end %>
              </ol>
            </div>
          <% end %>
          
          <!-- Таймер -->
          <div class="mt-4">
            <h5>⏱️ Время практики:</h5>
            <div class="btn-group" role="group">
              <% content["exercise"]["timer_options"].each do |minutes| %>
                <button class="btn btn-outline-primary timer-option"
                        data-action="click->day-program#selectTimer"
                        data-day-program-target="timerButtons"
                        data-minutes="<%= minutes %>">
                  <%= minutes %> мин
                </button>
              <% end %>
              <button class="btn btn-outline-secondary timer-option"
                      data-action="click->day-program#selectTimer"
                      data-day-program-target="timerButtons"
                      data-minutes="custom">
                Свой вариант
              </button>
            </div>
          </div>

          <!-- Важное примечание -->
          <% if content["exercise"]["note"] %>
            <div class="alert alert-info mt-4">
              <i class="fas fa-lightbulb me-2"></i>
              <strong>💡 Важно:</strong> <%= content["exercise"]["note"] %>
            </div>
          <% end %>
          
          <!-- Кнопка начала -->
          <div class="text-center mt-4">
            <button class="btn btn-success btn-lg px-5" 
                    id="startPractice"
                    data-action="click->day-program#startPractice">
              <i class="fas fa-play me-2"></i>Начать практику
            </button>
          </div>
        </div>
      </div>

      <!-- Советы -->
      <% if content["tips"] %>
        <div class="card mb-4">
          <div class="card-body">
            <h4 class="card-title">
              <i class="fas fa-lightbulb text-warning me-2"></i>
              💡 Полезные советы
            </h4>
            <ul class="mt-3">
              <% content["tips"].each do |tip| %>
                <li class="mb-2"><%= tip %></li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>

      <!-- Рефлексия -->
      <div id="reflectionSection" class="card mb-4 d-none" data-day-program-target="reflection">
        <div class="card-body">
          <h4 class="card-title">
            <i class="fas fa-pen me-2"></i>
            Рефлексия после практики
          </h4>
          <p>Как вы себя чувствуете после практики?</p>
          <textarea class="form-control" rows="3" placeholder="Напишите свои ощущения..."></textarea>
        </div>
      </div>

    <% else %>
      <!-- Старый рендеринг для 28-дневной программы -->
      <% if content["intro"].present? %>
        <div class="card mb-4">
          <div class="card-body">
            <h4 class="card-title">
              <i class="fas fa-leaf text-success me-2"></i>
              <%= content["intro"]["title"] %>
            </h4>
            <p class="card-text"><%= content["intro"]["text"] %></p>
          </div>
        </div>
      <% end %>

      <%= render 'programs/shared/scientific_facts', content: content %>
      <%= render 'programs/shared/benefits', content: content %>

      <div class="card mb-4 border-primary">
        <div class="card-header bg-primary text-white">
          <h4 class="mb-0">
            <i class="fas fa-heartbeat me-2"></i>
            Практика дня
          </h4>
        </div>
        <div class="card-body">
          <% if day_has_techniques?(day.day_number) %>
            <%= render 'programs/shared/techniques', day: day, content: content %>
          <% end %>

          <% if day_has_timer?(day.day_number) %>
            <%= render 'programs/shared/timer', day: day, content: content %>
          <% end %>
        </div>
      </div>

      <%= render 'programs/shared/reflection', content: content %>
      <%= render 'programs/shared/challenges', content: content %>
      <%= render 'programs/shared/daily_tips', content: content %>
    <% end %>

    <!-- Завершение дня -->
    <div class="text-center mt-5">
      <button class="btn btn-success btn-lg px-5 d-none" 
              id="completeDay"
              data-action="click->day-program#completeDay">
        <i class="fas fa-check-circle me-2"></i>Завершить день
      </button>
      <p class="text-secondary mt-2 small">
        <i class="fas fa-clock me-1"></i>
        Следующий день будет доступен через 12 часов
      </p>
    </div>
  </div>
</div>

<!-- Стили -->
<%= render 'programs/shared/styles' %>

<!-- Таймер с звуком через Web Audio API -->
<script>
  (function() {
    let timerInterval = null
    let startBtn = null
    let audioCtx = null
    
    function playSound() {
      if (!audioCtx) return
      const now = audioCtx.currentTime
      
      const osc = audioCtx.createOscillator()
      const gain = audioCtx.createGain()
      osc.connect(gain)
      gain.connect(audioCtx.destination)
      osc.type = 'sine'
      osc.frequency.value = 880
      gain.gain.value = 0.3
      osc.start()
      gain.gain.exponentialRampToValueAtTime(0.00001, now + 0.5)
      osc.stop(now + 0.5)
      
      setTimeout(() => {
        if (!audioCtx) return
        const osc2 = audioCtx.createOscillator()
        const gain2 = audioCtx.createGain()
        osc2.connect(gain2)
        gain2.connect(audioCtx.destination)
        osc2.type = 'sine'
        osc2.frequency.value = 660
        gain2.gain.value = 0.3
        osc2.start()
        gain2.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + 0.5)
        osc2.stop(audioCtx.currentTime + 0.5)
      }, 200)
    }
    
    function showNotification() {
      const notif = document.createElement('div')
      notif.className = 'alert alert-success position-fixed top-0 start-50 translate-middle-x mt-3'
      notif.style.zIndex = '9999'
      notif.innerHTML = '✅ Время практики закончилось!'
      document.body.appendChild(notif)
      setTimeout(() => notif.remove(), 3000)
    }
    
    function initTimer() {
      startBtn = document.getElementById('startPractice')
      if (!startBtn) return
      
      // Удаляем старый обработчик
      const newBtn = startBtn.cloneNode(true)
      startBtn.parentNode.replaceChild(newBtn, startBtn)
      startBtn = newBtn
      
      startBtn.addEventListener('click', function() {
        // Инициализируем и "будим" аудиоконтекст
        if (!audioCtx) {
          audioCtx = new (window.AudioContext || window.webkitAudioContext)()
        }
        if (audioCtx.state === 'suspended') {
          audioCtx.resume()
        }
        
        // Находим выбранное время
        const selectedBtn = document.querySelector('.timer-option.btn-primary')
        if (!selectedBtn) {
          alert('Сначала выберите время практики')
          return
        }
        
        let minutes = parseInt(selectedBtn.dataset.minutes)
          if (isNaN(minutes)) {
            minutes = parseInt(prompt('Введите количество минут (1-30):', '5'))
            if (isNaN(minutes) || minutes < 1 || minutes > 30) {
              alert('Введите число от 1 до 30')
              return
            }
          }
        if (isNaN(minutes)) minutes = 5
        
        let seconds = minutes * 60
        startBtn.disabled = true
        startBtn.textContent = '⏳ Идёт практика...'
        
        if (timerInterval) clearInterval(timerInterval)
        
        timerInterval = setInterval(function() {
          seconds--
          if (seconds <= 0) {
            clearInterval(timerInterval)
            showNotification()
            playSound()
            startBtn.disabled = false
            startBtn.textContent = '▶️ Начать практику'
            
            // Показываем рефлексию
            const reflectionSection = document.getElementById('reflectionSection')
            if (reflectionSection) {
              reflectionSection.classList.remove('d-none')
            }
          }
        }, 1000)
      })
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTimer)
    } else {
      initTimer()
    }
  })()
</script>

<!-- Стили для таймера -->
<style>
  .timer-option.btn-primary {
    background-color: #0d6efd;
    color: white;
  }
  .timer-option.btn-outline-primary {
    border-color: #0d6efd;
    color: #0d6efd;
  }
  .timer-option.btn-outline-primary:hover {
    background-color: #0d6efd;
    color: white;
  }
</style>