<div class="mt-4">
  <h5 class="mb-3">🔄 День 14: Промежуточная рефлексия</h5>
  <p class="text-secondary mb-4">Подводим итоги первых двух недель и создаем план на вторую половину программы.</p>
  
  <!-- Простое объяснение -->
  <div class="alert alert-info mb-4">
    <i class="fas fa-star me-2"></i>
    <strong>Вы прошли половину пути!</strong> Сегодня мы осмыслим достижения, инсайты и трудности, чтобы заложить основу для следующих 14 дней.
  </div>
  
  <!-- Статистика для мотивации -->
  <div class="row mb-4">
    <div class="col-6 col-md-3 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-success mb-0">14</h4>
          <small>дней</small>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-primary mb-0">13</h4>
          <small>техник</small>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-warning mb-0">50%</h4>
          <small>программы</small>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3 mb-2">
      <div class="card text-center bg-light">
        <div class="card-body py-2">
          <h4 class="text-danger mb-0">14</h4>
          <small>впереди</small>
        </div>
      </div>
    </div>
  </div>
  
  <!-- 5 категорий рефлексии (свернуто по умолчанию) -->
  <div class="accordion mb-4">
    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#reflectionCategories">
          📝 5 категорий рефлексии (нажмите для справки)
        </button>
      </h2>
      <div id="reflectionCategories" class="accordion-collapse collapse">
        <div class="accordion-body">
          <div class="row">
            <% content["reflection_categories"].each do |cat| %>
              <div class="col-12 mb-3">
                <span class="badge bg-success me-2"><%= cat["emoji"] %></span> 
                <strong><%= cat["name"] %></strong>
                <p class="text-secondary small mt-1 ms-4"><%= cat["prompt"] %></p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Кнопка начала -->
  <div class="text-center mt-4">
    <button class="btn btn-success btn-lg px-5" id="startTwoWeeksReflection">
      <i class="fas fa-pen me-2"></i>Начать рефлексию 2 недель
    </button>
    <p class="text-secondary small mt-2">Это займет 10-15 минут. Ответьте на вопросы в 5 категориях.</p>
  </div>
  
  <!-- Контейнер для шагов -->
  <div id="reflectionStepsContainer" style="display: none;"></div>
</div>