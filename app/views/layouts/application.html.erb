<!DOCTYPE html>
<html>
  <head>
    <link rel="manifest" href="/manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>PsyBotWeb</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
      html {
        scroll-behavior: smooth;
      }
    </style>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "custom", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div data-controller="push"
     data-push-vapid-public-key="<%= ENV['VAPID_PUBLIC_KEY'] %>"></div>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <%= link_to "PsyBot", root_path, class: "navbar-brand" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <%= link_to start_path, class: "nav-link" do %>
                <i class="fas fa-rocket"></i> С чего начать?
              <% end %>
            </li>

            <li class="nav-item">
              <%= link_to programs_path, class: "nav-link" do %>
                <i class="fas fa-seedling"></i> Программа
              <% end %>
            </li>

            <li class="nav-item">
              <%= link_to gratitude_entries_path, class: "nav-link" do %>
                <i class="fas fa-heart"></i> Благодарности
              <% end %>
            </li>

            <li class="nav-item">
              <%= link_to new_emotion_diary_path, class: "nav-link" do %>
                <i class="fas fa-book-open"></i> Дневник эмоций
              <% end %>
            </li>

            <li class="nav-item">
              <%= link_to tests_path, class: "nav-link" do %>
                <i class="fas fa-clipboard-list"></i> Тесты
              <% end %>
            </li>

            <li class="nav-item">
              <%= link_to support_path, class: "nav-link" do %>
                <i class="fas fa-headset"></i> Поддержка
              <% end %>
            </li>

            <% if user_signed_in? %>
              <% if current_user.admin? %>
                <li class="nav-item">
                  <%= link_to admin_dashboard_path, class: "nav-link" do %>
                    <i class="fas fa-crown"></i> Админ
                  <% end %>
                </li>
              <% end %>

              <li class="nav-item">
                <%= link_to profile_path, class: "nav-link" do %>
                  <i class="fas fa-user"></i> Профиль
                <% end %>
              </li>

              <li class="nav-item">
                <%= button_to destroy_user_session_path, 
                              method: :delete,
                              form_class: "d-inline",
                              class: "btn btn-link nav-link p-0 border-0",
                              data: { turbo: false } do %>
                  <i class="fas fa-sign-out-alt"></i> Выйти
                <% end %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to new_user_session_path, class: "nav-link" do %>
                  <i class="fas fa-sign-in-alt"></i> Войти
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to new_user_registration_path, class: "nav-link" do %>
                  <i class="fas fa-user-plus"></i> Регистрация
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container mt-4">
      <% if notice %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= notice %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
      
      <% if alert %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%= alert %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <%= yield :javascript %>
  </body>
</html>