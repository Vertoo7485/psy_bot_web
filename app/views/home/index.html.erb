<div class="hero-section text-center py-5">
  <div class="container">
    <div class="row align-items-center min-vh-75">
      <div class="col-lg-8 mx-auto">
        <!-- Анимированная иконка -->
        <div class="hero-icon mb-4">
          <i class="fas fa-brain fa-4x" style="color: var(--primary); opacity: 0.8;"></i>
        </div>
        
        <!-- Заголовок -->
        <h1 class="display-3 fw-bold mb-4" style="color: var(--text);">
          Путь к гармонии<br>
          <span style="color: var(--primary);">начинается здесь</span>
        </h1>
        
        <!-- Описание -->
        <p class="lead mb-5" style="color: var(--text-light); font-size: 1.3rem;">
          Тесты, дневник эмоций и персональные практики<br>
          для твоего ментального здоровья
        </p>
        
        <!-- Кнопки действий -->
        <div class="d-flex justify-content-center gap-3">
          <% if user_signed_in? %>
            <%= link_to profile_path, class: "btn btn-primary btn-lg px-5 py-3" do %>
              <i class="fas fa-user-circle me-2"></i>Мой профиль
            <% end %>
          <% else %>
            <%= link_to new_user_registration_path, class: "btn btn-primary btn-lg px-5 py-3" do %>
              <i class="fas fa-rocket me-2"></i>Начать бесплатно
            <% end %>
            
            <%= link_to new_user_session_path, class: "btn btn-outline-primary btn-lg px-5 py-3" do %>
              <i class="fas fa-sign-in-alt me-2"></i>Войти
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Преимущества -->
<div class="features-section py-5" style="background: var(--bg-alt);">
  <div class="container">
    <h2 class="section-title">Что вас ждёт</h2>
    
    <div class="row g-4">
      <div class="col-md-4">
        <div class="card h-100 text-center p-4">
          <div class="feature-icon">
            <i class="fas fa-clipboard-list"></i>
          </div>
          <h4>Тесты</h4>
          <p class="text-muted">Проверенные методики для оценки тревожности, депрессии и эмоционального состояния</p>
        </div>
      </div>
      
      <div class="col-md-4">
        <div class="card h-100 text-center p-4">
          <div class="feature-icon">
            <i class="fas fa-book-heart"></i>
          </div>
          <h4>Дневник эмоций</h4>
          <p class="text-muted">Отслеживайте своё настроение и находите закономерности</p>
        </div>
      </div>
      
      <div class="col-md-4">
        <div class="card h-100 text-center p-4">
          <div class="feature-icon">
            <i class="fas fa-seedling"></i>
          </div>
          <h4>Программа самопомощи</h4>
          <p class="text-muted">28 дней практик для улучшения ментального здоровья</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Призыв к действию для премиум -->
<div class="cta-section py-5">
  <div class="container">
    <div class="card text-center p-5" style="background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary) 100%); color: white;">
      <h2 class="mb-4" style="color: white;">Получите больше возможностей</h2>
      <p class="lead mb-4" style="color: rgba(255,255,255,0.9);">
        Премиум-доступ открывает расширенную программу,<br>персональные рекомендации и приоритетную поддержку
      </p>
      <%= link_to "#", class: "btn btn-light btn-lg px-5 py-3" do %>
        <i class="fas fa-crown me-2" style="color: var(--primary);"></i>Узнать о премиум
      <% end %>
    </div>
  </div>
</div>

<style>
  .min-vh-75 {
    min-height: 75vh;
  }
  
  .hero-icon {
    animation: float 3s ease-in-out infinite;
  }
  
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }
  
  .feature-icon {
    width: 80px;
    height: 80px;
    background: var(--primary-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    color: white;
    font-size: 2rem;
    transition: all 0.3s ease;
  }
  
  .feature-icon:hover {
    transform: scale(1.1) rotate(5deg);
    background: var(--primary);
  }
</style>