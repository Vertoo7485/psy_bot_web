<div class="row">
  <div class="col-md-8 offset-md-2">
    <div class="card">
      <div class="card-header bg-primary text-white">
        <h3 class="mb-0">Мой профиль</h3>
      </div>
      <div class="card-body">
        <div class="row mb-3">
          <div class="col-sm-3 fw-bold">Email:</div>
          <div class="col-sm-9"><%= @user.email %></div>
        </div>
        
        <div class="row mb-3">
          <div class="col-sm-3 fw-bold">Статус:</div>
          <div class="col-sm-9">
            <% if @user.premium? %>
              <span class="badge bg-success">Премиум</span>
            <% else %>
              <span class="badge bg-secondary">Бесплатный</span>
            <% end %>
          </div>
        </div>
        
        <% if @user.premium? %>
          <div class="row mb-3">
            <div class="col-sm-3 fw-bold">Подписка до:</div>
            <div class="col-sm-9">
              <%= @user.subscription_ends_at.strftime('%d.%m.%Y') %>
              <span class="badge bg-info ms-2">Осталось дней: <%= @user.days_until_subscription_ends %></span>
            </div>
          </div>
        <% end %>
        
        <div class="row mb-3">
          <div class="col-sm-3 fw-bold">Дата регистрации:</div>
          <div class="col-sm-9"><%= @user.created_at.strftime('%d.%m.%Y') %></div>
        </div>
        
        <div class="d-flex justify-content-between mt-4">
          <%= link_to "Редактировать профиль", edit_user_registration_path, class: "btn btn-outline-primary" %>
          <% unless @user.premium? %>
            <%= link_to "Оформить Premium", "#", class: "btn btn-success" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>